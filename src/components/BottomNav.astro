---
const items = [
  {
    href: '/',
    label: 'হোম',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`,
  },
  {
    href: '/symptom-diagnosis',
    label: 'ডায়াগনোসিস',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/><path d="M11 8v6M8 11h6"/></svg>`,
  },
  {
    href: '/appointment',
    label: 'বুকিং',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/><path d="M8 14h.01M12 14h.01M16 14h.01M8 18h.01M12 18h.01"/></svg>`,
    cta: true,
  },
  {
    href: '/blog',
    label: 'ব্লগ',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>`,
  },
  {
    href: '/profile',
    label: 'প্রোফাইল',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>`,
  },
];
---

<nav class="bottom-nav" aria-label="মোবাইল নেভিগেশন" transition:persist>
  {items.map(item => (
    <a
      href={item.href}
      class:list={[
        'bottom-nav-item',
        item.cta && 'bottom-nav-cta',
      ]}
      data-nav-href={item.href}
      data-nav-cta={item.cta ? 'true' : undefined}
      aria-label={item.label}
    >
      <span class="bottom-nav-icon" set:html={item.icon} />
      <span class="bottom-nav-label">{item.label}</span>
      {!item.cta && <span class="active-dot" aria-hidden="true"></span>}
    </a>
  ))}
</nav>

<script>
  function updateBottomNav() {
    const path = window.location.pathname;
    const links = document.querySelectorAll<HTMLAnchorElement>('[data-nav-href]');

    links.forEach(link => {
      const href = link.dataset.navHref ?? '';
      const isCta = link.dataset.navCta === 'true';
      if (isCta) return; // CTA never gets active state

      const active = href === '/' ? path === '/' : path.startsWith(href);

      link.classList.toggle('is-active', active);
      link.setAttribute('aria-current', active ? 'page' : '');
      if (!active) link.removeAttribute('aria-current');
    });
  }

  // Run on first load and after every View Transition navigation
  updateBottomNav();
  document.addEventListener('astro:page-load', updateBottomNav);
</script>

<style>
.bottom-nav {
  display: none;
}

@media (max-width: 768px) {
  .bottom-nav {
    display: flex;
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 200;
    background: #fff;
    border-top: 1px solid var(--border);
    box-shadow: 0 -4px 20px rgba(16,185,129,0.08), 0 -1px 0 rgba(0,0,0,0.04);
    padding-bottom: env(safe-area-inset-bottom, 0px);
    height: calc(64px + env(safe-area-inset-bottom, 0px));
    align-items: stretch;
  }

  .bottom-nav-item {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 3px;
    text-decoration: none;
    color: var(--text-muted);
    font-size: 10px;
    font-weight: 500;
    position: relative;
    transition: color 0.18s ease;
    padding: 6px 4px;
    /* Ripple-like active feedback */
    -webkit-tap-highlight-color: transparent;
  }

  .bottom-nav-item:active {
    opacity: 0.7;
    transform: scale(0.94);
    transition: transform 0.08s ease, opacity 0.08s ease;
  }

  .bottom-nav-item.is-active {
    color: var(--primary);
  }

  .bottom-nav-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    transition: transform 0.2s ease;
  }

  .bottom-nav-item.is-active .bottom-nav-icon {
    transform: translateY(-2px);
  }

  .bottom-nav-label {
    font-size: 10px;
    line-height: 1;
    white-space: nowrap;
  }

  /* Active indicator dot */
  .active-dot {
    position: absolute;
    top: 6px;
    width: 4px;
    height: 4px;
    background: var(--primary);
    border-radius: 50%;
  }

  /* CTA center button */
  .bottom-nav-cta {
    color: #fff;
    flex: 1.2;
  }

  .bottom-nav-cta .bottom-nav-icon {
    width: 48px;
    height: 48px;
    background: var(--primary);
    border-radius: 50%;
    box-shadow: 0 4px 16px rgba(16,185,129,0.4);
    margin-top: -16px;
    border: 3px solid #fff;
    transform: none !important;
    transition: background 0.2s, box-shadow 0.2s, transform 0.1s !important;
  }

  .bottom-nav-cta:active .bottom-nav-icon {
    background: var(--primary-dark);
    transform: scale(0.92) !important;
  }

  .bottom-nav-cta .bottom-nav-label {
    color: var(--primary);
    font-weight: 600;
  }
}
</style>
