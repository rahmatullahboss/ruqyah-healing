---
---
<section class="hero">
  <!-- Floating orb decorations -->
  <div class="hero-orb hero-orb--1" aria-hidden="true"></div>
  <div class="hero-orb hero-orb--2" aria-hidden="true"></div>
  <div class="hero-geometric" aria-hidden="true"></div>

  <div class="container hero-content">
    <div class="hero-badge">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
      </svg>
      <span>কুরআন ও সুন্নাহ ভিত্তিক হিলিং</span>
    </div>

    <h1 class="hero-title">Ruqyah Healing Center</h1>
    <p class="hero-subtitle">ইসলামী রুকইয়ার মাধ্যমে হালাল হিলিং সার্ভিস</p>
    <p class="hero-desc">কুরআন এবং সুন্নাহ ভিত্তিক চিকিৎসা পদ্ধতিতে আপনার আধ্যাত্মিক ও শারীরিক সুস্থতা নিশ্চিত করুন</p>

    <div class="hero-actions">
      <a href="/appointment" class="btn btn-hero-primary">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
          <line x1="16" y1="2" x2="16" y2="6"/>
          <line x1="8" y1="2" x2="8" y2="6"/>
          <line x1="3" y1="10" x2="21" y2="10"/>
        </svg>
        এ্যাপয়েনমেন্ট নিন
      </a>
      <a href="/symptom-diagnosis" class="btn btn-outline-white">
        ডায়াগনোসিস শুরু করুন
      </a>
    </div>

    <!-- Stats strip -->
    <div class="hero-stats">
      <div class="hero-stat">
        <span class="hero-stat-num">৫০০+</span>
        <span class="hero-stat-label">সুচিকিৎসিত রোগী</span>
      </div>
      <div class="hero-stat-divider"></div>
      <div class="hero-stat">
        <span class="hero-stat-num">৩+</span>
        <span class="hero-stat-label">বছরের অভিজ্ঞতা</span>
      </div>
      <div class="hero-stat-divider"></div>
      <div class="hero-stat">
        <span class="hero-stat-num">১০০%</span>
        <span class="hero-stat-label">হালাল পদ্ধতি</span>
      </div>
    </div>
  </div>
</section>

<style>
.hero {
  position: relative;
  min-height: 560px;
  display: flex;
  align-items: center;
  background:
    linear-gradient(135deg, #059669 0%, #065f46 50%, #047857 100%);
  overflow: hidden;
}

/* Subtle Islamic geometric grid overlay */
.hero::before {
  content: '';
  position: absolute;
  inset: 0;
  background-image:
    repeating-linear-gradient(45deg, rgba(255,255,255,0.04) 0px, rgba(255,255,255,0.04) 1px, transparent 1px, transparent 48px),
    repeating-linear-gradient(-45deg, rgba(255,255,255,0.04) 0px, rgba(255,255,255,0.04) 1px, transparent 1px, transparent 48px);
  pointer-events: none;
}

/* Floating orbs */
.hero-orb {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
  animation: float 6s ease-in-out infinite;
}
.hero-orb--1 {
  width: 380px;
  height: 380px;
  top: -120px;
  right: -80px;
  background: radial-gradient(circle, rgba(16,185,129,0.35) 0%, transparent 70%);
  animation-delay: 0s;
}
.hero-orb--2 {
  width: 260px;
  height: 260px;
  bottom: -80px;
  left: 10%;
  background: radial-gradient(circle, rgba(52,211,153,0.25) 0%, transparent 70%);
  animation-delay: 3s;
}

/* Geometric decorative element */
.hero-geometric {
  position: absolute;
  right: 8%;
  top: 50%;
  transform: translateY(-50%);
  width: 240px;
  height: 240px;
  border: 1px solid rgba(255,255,255,0.12);
  border-radius: 50%;
  pointer-events: none;
}
.hero-geometric::before {
  content: '';
  position: absolute;
  inset: 24px;
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: 50%;
}
.hero-geometric::after {
  content: '';
  position: absolute;
  inset: 48px;
  border: 1px solid rgba(255,255,255,0.06);
  border-radius: 50%;
}

@keyframes float {
  0%, 100% { transform: translateY(0px); }
  50% { transform: translateY(-20px); }
}

.hero-content {
  position: relative;
  text-align: center;
  padding-top: 80px;
  padding-bottom: 80px;
  color: #fff;
}

/* Badge */
.hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: rgba(255,255,255,0.15);
  backdrop-filter: blur(8px);
  border: 1px solid rgba(255,255,255,0.25);
  color: rgba(255,255,255,0.95);
  font-size: 13px;
  font-weight: 600;
  padding: 6px 16px;
  border-radius: 20px;
  margin-bottom: 22px;
  letter-spacing: 0.3px;
}

.hero-title {
  font-family: 'Lora', 'Hind Siliguri', serif;
  font-size: clamp(30px, 5.5vw, 52px);
  font-weight: 700;
  margin-bottom: 14px;
  letter-spacing: -0.5px;
  line-height: 1.15;
}

.hero-subtitle {
  font-size: clamp(17px, 3vw, 24px);
  font-weight: 600;
  margin-bottom: 14px;
  color: rgba(255,255,255,0.92);
}

.hero-desc {
  font-size: 16px;
  color: rgba(255,255,255,0.78);
  max-width: 580px;
  margin: 0 auto 36px;
  line-height: 1.75;
}

.hero-actions {
  display: flex;
  gap: 14px;
  justify-content: center;
  flex-wrap: wrap;
  margin-bottom: 48px;
}

/* Primary hero button — white fill */
.btn-hero-primary {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 13px 28px;
  border-radius: 24px;
  font-size: 15px;
  font-weight: 700;
  cursor: pointer;
  background: #fff;
  color: #059669;
  border: 2px solid #fff;
  transition: all 0.2s ease;
  font-family: inherit;
}
.btn-hero-primary:hover {
  background: rgba(255,255,255,0.92);
  transform: translateY(-2px);
  box-shadow: 0 6px 20px rgba(0,0,0,0.2);
}

/* Stats strip */
.hero-stats {
  display: inline-flex;
  align-items: center;
  gap: 0;
  background: rgba(255,255,255,0.1);
  backdrop-filter: blur(8px);
  border: 1px solid rgba(255,255,255,0.2);
  border-radius: 16px;
  padding: 16px 32px;
  gap: 32px;
}
.hero-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2px;
}
.hero-stat-num {
  font-size: 22px;
  font-weight: 700;
  color: #fff;
  line-height: 1;
}
.hero-stat-label {
  font-size: 12px;
  color: rgba(255,255,255,0.72);
  white-space: nowrap;
}
.hero-stat-divider {
  width: 1px;
  height: 36px;
  background: rgba(255,255,255,0.2);
}

@media (max-width: 768px) {
  .hero-geometric { display: none; }
  .hero-stats { gap: 20px; padding: 14px 20px; }
  .hero-stat-num { font-size: 18px; }
}

@media (max-width: 480px) {
  .hero-stats { flex-wrap: wrap; justify-content: center; }
  .hero-stat-divider { display: none; }
}
</style>
