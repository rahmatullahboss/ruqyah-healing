<section class="hero">
  <!-- Three.js WebGL Canvas — floating Islamic star particles -->
  <canvas id="hero-canvas" aria-hidden="true"></canvas>

  <!-- Floating orb decorations (CSS) -->
  <div class="hero-orb hero-orb--1" aria-hidden="true"></div>
  <div class="hero-orb hero-orb--2" aria-hidden="true"></div>

  <div class="container hero-content">
    <div class="hero-badge">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
      </svg>
      <span>কুরআন ও সুন্নাহ ভিত্তিক হিলিং</span>
    </div>

    <h1 class="hero-title">Ruqyah Healing Center</h1>
    <p class="hero-subtitle">ইসলামী রুকইয়ার মাধ্যমে হালাল হিলিং সার্ভিস</p>
    <p class="hero-desc">কুরআন এবং সুন্নাহ ভিত্তিক চিকিৎসা পদ্ধতিতে আপনার আধ্যাত্মিক ও শারীরিক সুস্থতা নিশ্চিত করুন</p>

    <div class="hero-actions">
      <a href="/appointment" class="btn btn-hero-primary">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
          <line x1="16" y1="2" x2="16" y2="6"/>
          <line x1="8" y1="2" x2="8" y2="6"/>
          <line x1="3" y1="10" x2="21" y2="10"/>
        </svg>
        অ্যাপয়েন্টমেন্ট নিন
      </a>
      <a href="/symptom-diagnosis" class="btn btn-outline-white">
        ডায়াগনোসিস শুরু করুন
      </a>
    </div>

    <!-- Stats strip — data-count triggers counter animation -->
    <div class="hero-stats">
      <div class="hero-stat">
        <span
          class="hero-stat-num"
          data-count="500"
          data-suffix="+"
          aria-label="৫০০+ সুচিকিৎসিত রোগী"
        >৫০০+</span>
        <span class="hero-stat-label">সুচিকিৎসিত রোগী</span>
      </div>
      <div class="hero-stat-divider"></div>
      <div class="hero-stat">
        <span
          class="hero-stat-num"
          data-count="3"
          data-suffix="+"
          aria-label="৩+ বছরের অভিজ্ঞতা"
        >৩+</span>
        <span class="hero-stat-label">বছরের অভিজ্ঞতা</span>
      </div>
      <div class="hero-stat-divider"></div>
      <div class="hero-stat">
        <span
          class="hero-stat-num"
          data-count="100"
          data-suffix="%"
          aria-label="১০০% হালাল পদ্ধতি"
        >১০০%</span>
        <span class="hero-stat-label">হালাল পদ্ধতি</span>
      </div>
    </div>
  </div>
</section>

<!-- Three.js CDN — is:inline so Astro doesn't bundle it -->
<script is:inline>
(function () {
  'use strict';

  // Cache Three.js module globally to avoid re-importing on each navigation
  // window.__THREE__ is set after first successful import
  function initThree(THREE) {
    const canvas = document.getElementById('hero-canvas');
    if (!canvas) return;

    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (prefersReduced) return;

    const { Scene, PerspectiveCamera, WebGLRenderer, BufferGeometry, BufferAttribute, PointsMaterial, Points, AdditiveBlending } = THREE;

    const section = canvas.closest('.hero');
    if (!section) return;
    const W = section.offsetWidth;
    const H = section.offsetHeight;

    const renderer = new WebGLRenderer({ canvas, alpha: true, antialias: false });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 1.5));
    renderer.setSize(W, H);

    const scene = new Scene();
    const camera = new PerspectiveCamera(60, W / H, 0.1, 100);
    camera.position.z = 30;

    const COUNT = window.innerWidth < 768 ? 60 : 140;
    const positions = new Float32Array(COUNT * 3);
    const sizes = new Float32Array(COUNT);
    for (let i = 0; i < COUNT; i++) {
      positions[i * 3]     = (Math.random() - 0.5) * 60;
      positions[i * 3 + 1] = (Math.random() - 0.5) * 35;
      positions[i * 3 + 2] = (Math.random() - 0.5) * 20;
      sizes[i] = Math.random() * 2.5 + 0.8;
    }

    const geo = new BufferGeometry();
    geo.setAttribute('position', new BufferAttribute(positions, 3));
    geo.setAttribute('size', new BufferAttribute(sizes, 1));

    const mat = new PointsMaterial({
      color: 0x6ee7b7,
      size: 0.35,
      transparent: true,
      opacity: 0.55,
      blending: AdditiveBlending,
      depthWrite: false,
      sizeAttenuation: true,
    });

    const points = new Points(geo, mat);
    scene.add(points);

    let frame;
    let elapsed = 0;
    function animate() {
      frame = requestAnimationFrame(animate);
      elapsed += 0.004;
      points.rotation.y = elapsed * 0.15;
      points.rotation.x = Math.sin(elapsed * 0.08) * 0.06;
      renderer.render(scene, camera);
    }
    animate();

    const ro = new ResizeObserver(() => {
      const nw = section.offsetWidth;
      const nh = section.offsetHeight;
      camera.aspect = nw / nh;
      camera.updateProjectionMatrix();
      renderer.setSize(nw, nh);
    });
    ro.observe(section);

    // Cleanup before next page swap
    document.addEventListener('astro:before-swap', () => {
      cancelAnimationFrame(frame);
      ro.disconnect();
      renderer.dispose();
    }, { once: true });
  }

  function tryInit() {
    if (window.__THREE__) {
      // Module already loaded — just re-init
      initThree(window.__THREE__);
    } else {
      import('https://cdn.jsdelivr.net/npm/three@0.162.0/build/three.module.min.js')
        .then((THREE) => {
          window.__THREE__ = THREE; // Cache for future navigations
          initThree(THREE);
        })
        .catch(() => {}); // Silent fail
    }
  }

  // Run immediately on first load
  tryInit();
  // Re-run after every View Transition navigation to homepage
  document.addEventListener('astro:page-load', tryInit);
})();
</script>

<!-- Stats counter animation -->
<script>
function animateCounter(el: Element, target: number, suffix: string, duration = 1400) {
  const start = performance.now();
  const step = (now: number) => {
    const progress = Math.min((now - start) / duration, 1);
    // Ease-out cubic
    const eased = 1 - Math.pow(1 - progress, 3);
    el.textContent = Math.floor(eased * target) + suffix;
    if (progress < 1) requestAnimationFrame(step);
  };
  requestAnimationFrame(step);
}

function initCounters() {
  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (prefersReduced) return; // Leave static text as-is

  const counters = document.querySelectorAll<HTMLElement>('[data-count]');
  if (!counters.length) return;

  const obs = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (!entry.isIntersecting) return;
      const el = entry.target as HTMLElement;
      const target = parseInt(el.dataset.count ?? '0', 10);
      const suffix = el.dataset.suffix ?? '';
      animateCounter(el, target, suffix);
      obs.unobserve(el);
    });
  }, { threshold: 0.6 });

  counters.forEach(el => obs.observe(el));
}

// Run on initial load
initCounters();
// Re-run after Astro View Transitions navigate (ClientRouter)
document.addEventListener('astro:page-load', initCounters);
</script>

<style>
.hero {
  position: relative;
  min-height: 560px;
  display: flex;
  align-items: center;
  background:
    linear-gradient(135deg, rgba(5,150,105,0.88) 0%, rgba(6,95,70,0.92) 50%, rgba(4,120,87,0.88) 100%),
    url('/images/hero-bg.webp') center center / cover no-repeat;
  overflow: hidden;
}

/* Three.js canvas — fills hero section */
#hero-canvas {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: 0;
}

/* Subtle Islamic geometric grid overlay */
.hero::before {
  content: '';
  position: absolute;
  inset: 0;
  background-image:
    repeating-linear-gradient(45deg, rgba(255,255,255,0.04) 0px, rgba(255,255,255,0.04) 1px, transparent 1px, transparent 48px),
    repeating-linear-gradient(-45deg, rgba(255,255,255,0.04) 0px, rgba(255,255,255,0.04) 1px, transparent 1px, transparent 48px);
  pointer-events: none;
  z-index: 1;
}

/* Floating orbs */
.hero-orb {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
  animation: float 6s ease-in-out infinite;
  z-index: 1;
}
.hero-orb--1 {
  width: 380px;
  height: 380px;
  top: -120px;
  right: -80px;
  background: radial-gradient(circle, rgba(16,185,129,0.35) 0%, transparent 70%);
  animation-delay: 0s;
}
.hero-orb--2 {
  width: 260px;
  height: 260px;
  bottom: -80px;
  left: 10%;
  background: radial-gradient(circle, rgba(52,211,153,0.25) 0%, transparent 70%);
  animation-delay: 3s;
}

@keyframes float {
  0%, 100% { transform: translateY(0px); }
  50% { transform: translateY(-20px); }
}

.hero-content {
  position: relative;
  z-index: 2;     /* above canvas + overlays */
  text-align: center;
  padding-top: 80px;
  padding-bottom: 80px;
  color: #fff;
}

/* Badge */
.hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: rgba(255,255,255,0.15);
  backdrop-filter: blur(8px);
  border: 1px solid rgba(255,255,255,0.25);
  color: rgba(255,255,255,0.95);
  font-size: 13px;
  font-weight: 600;
  padding: 6px 16px;
  border-radius: 20px;
  margin-bottom: 22px;
  letter-spacing: 0.3px;
}

.hero-title {
  font-family: 'Lora', 'Hind Siliguri', serif;
  font-size: clamp(30px, 5.5vw, 52px);
  font-weight: 700;
  margin-bottom: 14px;
  letter-spacing: -0.5px;
  line-height: 1.15;
}

.hero-subtitle {
  font-size: clamp(17px, 3vw, 24px);
  font-weight: 600;
  margin-bottom: 14px;
  color: rgba(255,255,255,0.92);
}

.hero-desc {
  font-size: 16px;
  color: rgba(255,255,255,0.78);
  max-width: 580px;
  margin: 0 auto 36px;
  line-height: 1.75;
}

.hero-actions {
  display: flex;
  gap: 14px;
  justify-content: center;
  flex-wrap: wrap;
  margin-bottom: 48px;
}

/* Primary hero button */
.btn-hero-primary {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 13px 28px;
  border-radius: 24px;
  font-size: 15px;
  font-weight: 700;
  cursor: pointer;
  background: #fff;
  color: #059669;
  border: 2px solid #fff;
  transition: all 0.2s ease;
  font-family: inherit;
  min-height: 44px;
}
.btn-hero-primary:hover {
  background: rgba(255,255,255,0.92);
  transform: translateY(-2px);
  box-shadow: 0 6px 20px rgba(0,0,0,0.2);
}

/* Stats strip */
.hero-stats {
  display: inline-flex;
  align-items: center;
  gap: 32px;
  background: rgba(255,255,255,0.1);
  backdrop-filter: blur(8px);
  border: 1px solid rgba(255,255,255,0.2);
  border-radius: 16px;
  padding: 16px 32px;
}
.hero-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2px;
}
.hero-stat-num {
  font-size: 22px;
  font-weight: 700;
  color: #fff;
  line-height: 1;
  font-variant-numeric: tabular-nums;
  min-width: 3ch; /* avoid layout shift during count-up */
  display: inline-block;
}
.hero-stat-label {
  font-size: 12px;
  color: rgba(255,255,255,0.72);
  white-space: nowrap;
}
.hero-stat-divider {
  width: 1px;
  height: 36px;
  background: rgba(255,255,255,0.2);
}

@media (max-width: 768px) {
  .hero-stats { gap: 16px; padding: 12px 16px; }
  .hero-stat-num { font-size: 18px; }
  .hero-content { padding-top: 56px; padding-bottom: 56px; }
}

@media (max-width: 480px) {
  .hero { min-height: min(520px, 90svh); }
  .hero-actions {
    flex-direction: column;
    gap: 10px;
  }
  .hero-actions .btn,
  .hero-actions .btn-hero-primary,
  .hero-actions .btn-outline-white {
    width: 100%;
    justify-content: center;
  }
  .hero-stats {
    width: 100%;
    justify-content: space-around;
    gap: 8px;
    padding: 12px;
  }
  .hero-stat-divider { display: none; }
}

@media (prefers-reduced-motion: reduce) {
  .hero-orb { animation: none; }
}
</style>
