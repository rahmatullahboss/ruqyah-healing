---
// AIAgent.astro - A floating AI chat widget
---

<div id="ai-agent-widget" transition:persist="ai-agent" class="ai-agent-container">
  
  <!-- Chat Window -->
  <div id="ai-chat-window" class="ai-chat-window">
    <!-- Header -->
    <div class="ai-chat-header">
      <div class="ai-chat-title">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
        </svg>
        <h3>AI হিলিং অ্যাসিস্ট্যান্ট</h3>
      </div>
      <button id="ai-close-btn" class="ai-close-btn" aria-label="Close Chat">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <!-- Message Area -->
    <div id="ai-message-list" class="ai-message-list">
      <!-- Welcome Message -->
      <div class="ai-msg-row ai">
        <div class="ai-bubble-ai">
          আসসালামু আলাইকুম! রুকইয়াহ এবং ইসলামিক হিলিং সম্পর্কিত কোনো বিষয়ে আমার সাহায্য প্রয়োজন?
        </div>
      </div>
    </div>

    <!-- Input Area -->
    <div class="ai-chat-input-area">
      <form id="ai-chat-form" class="ai-chat-form">
        <input 
          type="text" 
          id="ai-chat-input" 
          class="ai-chat-input" 
          placeholder="আপনার প্রশ্ন লিখুন..." 
          required 
          autocomplete="off"
        />
        <button type="submit" id="ai-send-btn" class="ai-send-btn">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
          </svg>
        </button>
      </form>
    </div>
  </div>

  <!-- Toggle Button (Floating Action Button) -->
  <button id="ai-toggle-btn" class="ai-toggle-btn" aria-label="Open AI Assistant">
    <div class="ai-toggle-wrap">
      <svg xmlns="http://www.w3.org/2000/svg" class="ai-toggle-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" />
      </svg>
      <!-- Notification dot -->
      <span class="ai-notification-dot"></span>
    </div>
  </button>
</div>

<script>
  // Component setup
  document.addEventListener('astro:page-load', () => {
    // Prevent multiple initializations if the component persists
    if ((window as any)._aiAgentInitialized) return;
    (window as any)._aiAgentInitialized = true;
    const toggleBtn = document.getElementById('ai-toggle-btn');
    const closeBtn = document.getElementById('ai-close-btn');
    const chatWindow = document.getElementById('ai-chat-window');
    const chatForm = document.getElementById('ai-chat-form') as HTMLFormElement;
    const chatInput = document.getElementById('ai-chat-input') as HTMLInputElement;
    const messageList = document.getElementById('ai-message-list');
    const sendBtn = document.getElementById('ai-send-btn') as HTMLButtonElement;

    // Chat State
    let messages = [];
    let isChatOpen = false;

    // Toggle logic
    const toggleChat = () => {
      isChatOpen = !isChatOpen;
      if (isChatOpen) {
        chatWindow?.classList.add('is-open');
        // trigger animation
        setTimeout(() => {
          chatWindow?.classList.add('is-visible');
          chatInput?.focus();
        }, 10);
      } else {
        chatWindow?.classList.remove('is-visible');
        setTimeout(() => {
          chatWindow?.classList.remove('is-open');
        }, 300);
      }
    };

    toggleBtn?.addEventListener('click', toggleChat);
    closeBtn?.addEventListener('click', toggleChat);

    // Helper to escape HTML to prevent XSS
    const escapeHTML = (str: string) => {
      return str
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#039;');
    };

    // Simple markdown to HTML parser for basic output (bold, lists, links)
    const parseMarkdown = (text: string) => {
      let escaped = escapeHTML(text);
      let html = escaped
        .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
        .replace(/\*(.*?)\*/g, '<em>$1</em>')
        .replace(/`([^`]+)`/g, '<code>$1</code>')
        .replace(/\[(.*?)\]\((.*?)\)/g, '<a href="$2" target="_blank">$1</a>')
        .replace(/\n\n/g, '<br><br>')
        .replace(/\n/g, '<br>');
      return html;
    };

    // UI Builders
    const appendUserMessage = (text: string) => {
      const msgDiv = document.createElement('div');
      msgDiv.className = "ai-msg-row user";
      msgDiv.innerHTML = `
        <div class="ai-bubble-user">
          ${escapeHTML(text)}
        </div>
      `;
      messageList?.appendChild(msgDiv);
      scrollToBottom();
    };

    const appendAiPlaceholder = () => {
      const msgDiv = document.createElement('div');
      msgDiv.className = "ai-msg-row ai ai-response-container";
      msgDiv.innerHTML = `
        <div class="ai-bubble-ai">
          <div class="ai-typing-dots">
            <span class="ai-typing-dot"></span>
            <span class="ai-typing-dot"></span>
            <span class="ai-typing-dot"></span>
          </div>
        </div>
      `;
      messageList?.appendChild(msgDiv);
      scrollToBottom();
      return msgDiv;
    };

    const scrollToBottom = () => {
      if (messageList) {
        messageList.scrollTop = messageList.scrollHeight;
      }
    };

    // Form Handling
    chatForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const text = chatInput.value.trim();
      if (!text) return;

      // 1. Add user message
      appendUserMessage(text);
      messages.push({ role: 'user', content: text });
      chatInput.value = '';
      sendBtn.disabled = true;

      // 2. Add AI Placeholder
      const aiContainer = appendAiPlaceholder();
      const aiBubble = aiContainer.querySelector('.ai-bubble-ai') as HTMLDivElement;

      try {
        // 3. Fetch API
        const res = await fetch('/api/chat', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ messages })
        });

        if (!res.ok) {
          throw new Error('API Error: ' + res.statusText);
        }

        // 4. Stream reading
        const reader = res.body?.getReader();
        if (!reader) throw new Error("No response body.");
        
        const decoder = new TextDecoder();
        let aiText = '';
        let buffer = '';
        aiBubble.innerHTML = '';

        while (true) {
          const { done, value } = await reader.read();
          if (done) break;

          buffer += decoder.decode(value, { stream: true });
          const lines = buffer.split('\n');
          buffer = lines.pop() || '';

          for (const line of lines) {
            if (line.startsWith('data: ')) {
              const dataStr = line.slice(6).trim();
              if (dataStr === '[DONE]') break;
              if (!dataStr) continue;

              try {
                const data = JSON.parse(dataStr);
                const delta = data.choices?.[0]?.delta?.content;
                if (delta) {
                  aiText += delta;
                  aiBubble.innerHTML = parseMarkdown(aiText);
                  scrollToBottom();
                }
              } catch (parseError) {
                // partial chunk or invalid json
              }
            }
          }
        }

        // Finalize message
        messages.push({ role: 'assistant', content: aiText });

      } catch (error) {
        console.error(error);
        aiBubble.innerHTML = 'Sorry, there was an error processing your request. Please try again.';
        aiBubble.classList.add('ai-bubble-error');
        messages.pop(); // remove failed user message from context
      } finally {
        sendBtn.disabled = false;
        chatInput.focus();
      }
    });
  });
</script>

<style>
  /* Container */
  .ai-agent-container {
    position: fixed;
    bottom: 24px;
    left: 24px;
    z-index: 50;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    font-family: 'Hind Siliguri', 'Raleway', 'Inter', sans-serif;
  }
  
  @media (max-width: 768px) {
    .ai-agent-container {
      bottom: 80px; /* Above the mobile bottom navigation */
      left: 16px;
    }
  }

  /* Chat Window */
  .ai-chat-window {
    display: none;
    flex-direction: column;
    width: 350px;
    height: 500px;
    max-height: 70vh;
    background: #fff;
    border-radius: 16px;
    box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
    overflow: hidden;
    border: 1px solid #e5e7eb;
    margin-bottom: 16px;
    transform: scale(0.95);
    opacity: 0;
    transform-origin: bottom left;
    transition: all 0.3s ease;
  }
  
  .ai-chat-window.is-open {
    display: flex;
  }
  
  .ai-chat-window.is-visible {
    transform: scale(1);
    opacity: 1;
  }
  
  @media (min-width: 640px) {
    .ai-chat-window { width: 380px; }
  }

  /* Header */
  .ai-chat-header {
    background: var(--primary);
    color: #fff;
    padding: 16px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
  }
  
  .ai-chat-title {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  
  .ai-chat-title h3 {
    font-size: 1.125rem;
    font-weight: 700;
    margin: 0;
  }
  
  .ai-chat-title svg {
    width: 24px;
    height: 24px;
    color: var(--primary-light);
  }
  
  .ai-close-btn {
    color: #fff;
    padding: 4px;
    border-radius: 6px;
    transition: background-color 0.2s;
    background: transparent;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  .ai-close-btn:hover { background: var(--primary-dark); }
  .ai-close-btn svg { width: 20px; height: 20px; }

  /* Messages */
  .ai-message-list {
    flex: 1;
    overflow-y: auto;
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    background: #f9fafb;
    font-size: 0.875rem;
  }
  
  .ai-msg-row {
    display: flex;
    flex-direction: column;
    gap: 4px;
    margin-bottom: 8px;
    animation: fadeIn 0.3s ease-in-out;
  }
  
  .ai-msg-row.user { align-items: flex-end; }
  .ai-msg-row.ai { align-items: flex-start; }
  
  .ai-bubble-user {
    background: #1f2937;
    color: #fff;
    border: 1px solid #374151;
    border-radius: 16px;
    border-top-right-radius: 2px;
    padding: 8px 16px;
    max-width: 85%;
    word-break: break-word;
    box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
  }
  
  .ai-bubble-ai {
    background: var(--primary-light);
    color: var(--text-dark);
    border: 1px solid var(--border);
    border-radius: 16px;
    border-top-left-radius: 2px;
    padding: 12px 16px;
    max-width: 85%;
    word-break: break-word;
    box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
    line-height: 1.5;
  }
  
  .ai-bubble-error {
    background: #fef2f2;
    color: #dc2626;
    border-color: #fecaca;
  }
  
  .ai-bubble-ai a { color: var(--primary-dark); text-decoration: underline; }
  .ai-bubble-ai code { background: rgba(0,0,0,0.05); padding: 2px 6px; border-radius: 4px; color: #db2777; font-family: monospace; }
  .ai-bubble-ai strong { font-weight: 700; color: #064e3b; }
  .ai-bubble-ai em { font-style: italic; }

  /* Typing dots */
  .ai-typing-dots { display: flex; gap: 4px; align-items: center; height: 20px; }
  .ai-typing-dot { width: 8px; height: 8px; background: var(--primary); border-radius: 50%; animation: aiBounce 1s infinite; }
  .ai-typing-dot:nth-child(1) { animation-delay: -0.3s; }
  .ai-typing-dot:nth-child(2) { animation-delay: -0.15s; }
  
  @keyframes aiBounce {
    0%, 100% { transform: translateY(-25%); animation-timing-function: cubic-bezier(0.8,0,1,1); }
    50% { transform: none; animation-timing-function: cubic-bezier(0,0,0.2,1); }
  }

  /* Input Area */
  .ai-chat-input-area {
    padding: 12px;
    background: #fff;
    border-top: 1px solid #e5e7eb;
  }
  
  .ai-chat-form {
    display: flex;
    gap: 8px;
    margin: 0;
  }
  
  .ai-chat-input {
    flex: 1;
    background: #f3f4f6;
    border: 1px solid #d1d5db;
    color: #1f2937;
    font-size: 0.875rem;
    border-radius: 9999px;
    padding: 8px 16px;
    outline: none;
    transition: all 0.2s;
    font-family: inherit;
  }
  
  .ai-chat-input:focus {
    background: #fff;
    border-color: var(--primary);
    box-shadow: 0 0 0 2px var(--primary-light);
  }
  
  .ai-send-btn {
    background: var(--primary);
    color: #fff;
    border-radius: 9999px;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.2s;
    border: none;
    cursor: pointer;
  }
  
  .ai-send-btn:hover { background: var(--primary-dark); transform: scale(1.05); }
  .ai-send-btn:active { transform: scale(0.95); }
  .ai-send-btn:disabled { opacity: 0.5; cursor: not-allowed; }
  .ai-send-btn svg { width: 20px; height: 20px; margin-left: 2px; }

  /* Toggle Button */
  .ai-toggle-btn {
    background: var(--primary);
    color: #fff;
    border-radius: 50%;
    padding: 12px;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s;
    cursor: pointer;
    border: none;
  }
  
  .ai-toggle-btn:hover { 
    background: var(--primary-dark); 
    transform: translateY(-4px); 
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1); 
  }
  
  .ai-toggle-wrap { position: relative; display: flex; align-items: center; justify-content: center; }
  .ai-toggle-icon { width: 32px; height: 32px; transition: transform 0.3s; }
  .ai-toggle-btn:hover .ai-toggle-icon { transform: scale(1.1); }
  
  .ai-notification-dot {
    position: absolute;
    top: 0;
    right: 0;
    width: 12px;
    height: 12px;
    background: #ef4444;
    border: 2px solid #fff;
    border-radius: 50%;
    animation: aiPulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }
  
  @keyframes aiPulse {
    0%, 100% { opacity: 1; }
    50% { opacity: .5; }
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>

