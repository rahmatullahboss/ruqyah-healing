---
// src/components/PrayerTimes.astro
---

<div class="prayer-times-wrapper scroll-reveal" id="prayer-widget-container">
  <!-- Mandala Decoration (Top Right) -->
  <div class="mandala-deco">
    <svg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg" width="150" height="150">
      <path d="M100 0 C110 40 160 40 200 50 C160 60 160 110 150 200 C140 160 90 160 50 150 C90 140 90 90 100 0 Z" fill="none" stroke="#2e7d32" stroke-width="1" opacity="0.3"/>
      <circle cx="100" cy="100" r="40" fill="none" stroke="#2e7d32" stroke-width="1" opacity="0.4" stroke-dasharray="4 4" />
      <circle cx="100" cy="100" r="60" fill="none" stroke="#2e7d32" stroke-width="1" opacity="0.3" />
      <!-- Adding more floral shapes -->
      <path d="M100 20 Q120 60 100 100 Q80 60 100 20 Z" fill="none" stroke="#2e7d32" stroke-width="1" opacity="0.4" />
      <path d="M180 100 Q140 120 100 100 Q140 80 180 100 Z" fill="none" stroke="#2e7d32" stroke-width="1" opacity="0.4" />
      <path d="M100 180 Q120 140 100 100 Q80 140 100 180 Z" fill="none" stroke="#2e7d32" stroke-width="1" opacity="0.4" />
      <path d="M20 100 Q60 120 100 100 Q60 80 20 100 Z" fill="none" stroke="#2e7d32" stroke-width="1" opacity="0.4" />
    </svg>
  </div>

  <!-- Background Landscape (Left Bottom) -->
  <div class="landscape-deco">
    <svg viewBox="0 0 400 150" preserveAspectRatio="xMinYMax slice" xmlns="http://www.w3.org/2000/svg">
      <!-- Big Orange Sun -->
      <circle cx="80" cy="80" r="60" fill="#FFA756" />
      <!-- Distant small trees / hills -->
      <ellipse cx="40" cy="110" rx="20" ry="30" fill="#9CD0A2" opacity="0.8"/>
      <ellipse cx="120" cy="120" rx="15" ry="25" fill="#8AC791" opacity="0.8"/>
      <!-- River / Lake -->
      <ellipse cx="160" cy="130" rx="60" ry="8" fill="#B0C4DE" opacity="0.6"/>
      <!-- Foreground hills -->
      <path d="M-50 150 Q 80 80 200 150 Z" fill="#E6F2E8" />
      <path d="M100 150 Q 250 90 450 150 Z" fill="#F0F7F1" />
      <path d="M-20 150 Q 150 110 400 150 Z" fill="#E8F4EA" opacity="0.7"/>
    </svg>
  </div>

  <div class="prayer-times-content">
    
    <!-- Left: Location -->
    <div class="location-box">
      <h2 class="city" id="pt-city">West Covina,</h2>
      <h3 class="country" id="pt-country">California</h3>
    </div>

    <!-- Right: Prayer Details -->
    <div class="prayers-box">
      <div class="prayers-header">
        <h2>Prayer Times</h2>
        <div class="sunrise-info">
          <span class="sunrise-time" id="pt-sunrise">5:15</span>
          <span class="sunrise-label">Sunrise</span>
        </div>
      </div>

      <div class="prayers-list">
        
        <!-- FAJR -->
        <div class="prayer-item" data-prayer="Fajr">
          <div class="prayer-icon-wrapper">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M12 4V2M17.6569 6.34315L19.0711 4.92893M20 12H22M17.6569 17.6569L19.0711 19.0711M12 20V22M6.34315 17.6569L4.92893 19.0711M4 12H2M6.34315 6.34315L4.92893 4.92893" stroke="#F58E34" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M15.5355 15.5355C17.4883 13.5828 17.4883 10.4169 15.5355 8.46427C13.5829 6.51163 10.4171 6.51163 8.46447 8.46427C6.51184 10.4169 6.51184 13.5828 8.46447 15.5355" stroke="#F58E34" stroke-width="2" stroke-linecap="round"/>
              <path d="M4 18H20" stroke="#377A40" stroke-width="3" stroke-linecap="round"/>
            </svg>
          </div>
          <span class="prayer-name">FAJR</span>
          <span class="prayer-time-val" id="pt-fajr">5:00am</span>
        </div>

        <!-- ZUHR -->
        <div class="prayer-item" data-prayer="Dhuhr">
          <div class="prayer-icon-wrapper">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="12" cy="12" r="5" fill="#F58E34"/>
              <path d="M12 2V4M12 20V22M4 12H2M22 12H20M19.0711 19.0711L17.6569 17.6569M6.34315 6.34315L4.92893 4.92893M19.0711 4.92893L17.6569 6.34315M6.34315 17.6569L4.92893 19.0711" stroke="#F58E34" stroke-width="2" stroke-linecap="round"/>
            </svg>
          </div>
          <span class="prayer-name">ZUHR</span>
          <span class="prayer-time-val" id="pt-dhuhr">1:30pm</span>
        </div>

        <!-- ASR -->
        <div class="prayer-item" data-prayer="Asr">
          <div class="prayer-icon-wrapper">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="12" cy="10" r="4" fill="#F58E34"/>
              <path d="M12 1V3M18.364 4.636L16.95 6.05M21 10H19M5.636 4.636L7.05 6.05M3 10H5" stroke="#F58E34" stroke-width="2" stroke-linecap="round"/>
              <path d="M7 16L12 18L17 16" stroke="#377A40" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M4 19H20" stroke="#377A40" stroke-width="2" stroke-linecap="round"/>
            </svg>
          </div>
          <span class="prayer-name">ASR</span>
          <span class="prayer-time-val" id="pt-asr">4:30pm</span>
        </div>

        <!-- MAGHRIB -->
        <div class="prayer-item" data-prayer="Maghrib">
          <div class="prayer-icon-wrapper">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="10" cy="12" r="5" fill="#F58E34"/>
              <path d="M10 3V5M17.0711 4.92893L15.6569 6.34315M4.34315 6.34315L2.92893 4.92893M20 12H22M2 12H0" stroke="#F58E34" stroke-width="2" stroke-linecap="round"/>
              <path d="M13 16C13 14.3431 14.3431 13 16 13C17.6569 13 19 14.3431 19 16C19 17.6569 17.6569 19 16 19H8" stroke="#377A40" stroke-width="2" stroke-linecap="round"/>
              <circle cx="16" cy="16" r="3" fill="#377A40"/>
            </svg>
          </div>
          <span class="prayer-name">MAGHRIB</span>
          <span class="prayer-time-val" id="pt-maghrib">6:00pm</span>
        </div>

        <!-- ISHA -->
        <div class="prayer-item" data-prayer="Isha">
          <div class="prayer-icon-wrapper">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79Z" fill="#377A40"/>
              <path d="M18 6L18.5 4.5L20 4L18.5 3.5L18 2L17.5 3.5L16 4L17.5 4.5L18 6Z" fill="#F58E34"/>
            </svg>
          </div>
          <span class="prayer-name">ISHA</span>
          <span class="prayer-time-val" id="pt-isha">8:00pm</span>
        </div>

      </div>
    </div>
  </div>
</div>

<style>
  .prayer-times-wrapper {
    position: relative;
    width: 100%;
    margin: 0 auto;
    background: #FAFAF8; /* very light greenish white */
    border-radius: 20px;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.05);
    overflow: hidden;
    padding: 40px 50px;
    min-height: 220px;
    display: flex;
    align-items: center;
    font-family: system-ui, -apple-system, sans-serif;
  }

  .mandala-deco {
    position: absolute;
    top: -20px;
    right: -20px;
    width: 180px;
    height: 180px;
    pointer-events: none;
  }
  .mandala-deco svg {
    width: 100%;
    height: 100%;
  }

  .landscape-deco {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 55%;
    height: 150px;
    pointer-events: none;
    z-index: 1;
  }
  .landscape-deco svg {
    width: 100%;
    height: 100%;
  }

  .prayer-times-content {
    position: relative;
    z-index: 2;
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    flex-wrap: wrap;
    gap: 30px;
  }

  /* Location Side */
  .location-box {
    flex: 1;
    min-width: 200px;
  }
  .location-box .city {
    font-size: 26px;
    font-weight: 700;
    color: #1A5D2E;
    margin: 0;
    line-height: 1.2;
  }
  .location-box .country {
    font-size: 16px;
    font-weight: 600;
    color: #377A40;
    margin: 0;
  }

  /* Prayers Side */
  .prayers-box {
    flex: 2;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .prayers-header {
    display: flex;
    flex-direction: column;
    gap: 5px;
  }
  .prayers-header h2 {
    font-size: 22px;
    font-weight: 700;
    color: #1A5D2E;
    margin: 0;
  }
  .sunrise-info {
    display: flex;
    align-items: center;
    gap: 6px;
    font-weight: 700;
    font-size: 15px;
  }
  .sunrise-time {
    color: #F58E34;
  }
  .sunrise-label {
    color: #1A5D2E;
  }

  .prayers-list {
    display: flex;
    gap: 28px;
    align-items: center;
    flex-wrap: wrap;
  }

  .prayer-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    transition: transform 0.2s;
  }
  .prayer-item.next-prayer {
    transform: scale(1.05);
  }

  .prayer-icon-wrapper {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .prayer-name {
    font-size: 12px;
    font-weight: 700;
    color: #377A40;
    letter-spacing: 0.5px;
    text-transform: uppercase;
  }

  .prayer-time-val {
    font-size: 15px;
    font-weight: 700;
    color: #558B5D;
  }

  @media (max-width: 768px) {
    .prayer-times-wrapper {
      flex-direction: column;
      padding: 30px 20px;
    }
    .landscape-deco {
      width: 100%;
    }
    .prayer-times-content {
      flex-direction: column;
      align-items: flex-start;
    }
    .prayers-list {
      justify-content: space-between;
      width: 100%;
      gap: 15px;
    }
    .prayer-item {
      gap: 4px;
    }
    .prayer-time-val {
      font-size: 13px;
    }
  }
</style>