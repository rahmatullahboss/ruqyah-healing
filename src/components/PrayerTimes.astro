---
// src/components/PrayerTimes.astro
---

<div class="prayer-times-wrapper scroll-reveal" id="prayer-widget-container">
  
  <!-- Top Right Mandala Decoration -->
  <div class="deco-mandala" aria-hidden="true">
    <svg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
      <g stroke="#2e7d32" fill="none" stroke-width="0.8" opacity="0.4">
        <!-- Center core -->
        <circle cx="200" cy="0" r="150" stroke-dasharray="4 6"/>
        <circle cx="200" cy="0" r="130" />
        <circle cx="200" cy="0" r="100" stroke-dasharray="2 4"/>
        <circle cx="200" cy="0" r="70" />
        <!-- Petals -->
        <path d="M200 0 Q 150 50 100 0 Z" />
        <path d="M200 0 Q 150 100 200 100 Z" />
        <path d="M200 0 Q 120 80 140 140 Z" />
        <path d="M200 0 Q 80 120 140 140 Z" />
        <!-- Outer repeating elements -->
        <path d="M200 130 Q 150 160 100 130" />
        <path d="M130 200 Q 160 150 130 100" />
      </g>
    </svg>
  </div>

  <!-- Bottom Left Landscape Decoration -->
  <div class="deco-landscape" aria-hidden="true">
    <svg viewBox="0 0 500 200" preserveAspectRatio="xMinYMax slice" xmlns="http://www.w3.org/2000/svg">
      <!-- Sun -->
      <circle cx="120" cy="110" r="70" fill="#FFB067" />
      <!-- Distant Hills / Trees -->
      <path d="M 40 150 Q 60 110 80 150 Z" fill="#A5D6A7" />
      <path d="M 160 150 Q 180 120 200 150 Z" fill="#A5D6A7" />
      <path d="M 220 150 Q 240 130 260 150 Z" fill="#A5D6A7" />
      <!-- Water -->
      <path d="M 120 160 Q 180 160 250 150 L 300 160 Z" fill="#90CAF9" opacity="0.6"/>
      <!-- Foreground Waves (Creates the sweeping green bottom) -->
      <path d="M -50 200 Q 150 120 300 180 T 600 160 L 600 250 L -50 250 Z" fill="#E8F5E9" />
      <path d="M -50 200 Q 100 160 250 200 T 550 180 L 550 250 L -50 250 Z" fill="#F1F8F1" opacity="0.8"/>
    </svg>
  </div>

  <div class="prayer-content">
    <!-- Left Column: Location -->
    <div class="location-col">
      <h2 class="city" id="pt-city">West Covina,</h2>
      <p class="country" id="pt-country">California</p>
    </div>

    <!-- Right Column: Times -->
    <div class="times-col">
      <div class="times-header">
        <h3 class="title">Prayer Times</h3>
        <p class="sunrise-info">
          <span class="time" id="pt-sunrise">5:15</span> 
          <span class="label">Sunrise</span>
        </p>
      </div>

      <div class="times-grid">
        <!-- Fajr -->
        <div class="time-item" data-prayer="Fajr">
          <div class="icon">
             <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#F58E34" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41" />
                <path d="M4 18h16" stroke="#2e7d32" stroke-width="3"/>
                <path d="M8 15a4 4 0 0 1 8 0" stroke="#F58E34"/>
             </svg>
          </div>
          <span class="name">FAJR</span>
          <span class="time-val" id="pt-fajr">5:00am</span>
        </div>

        <!-- Zuhr -->
        <div class="time-item" data-prayer="Dhuhr">
          <div class="icon">
             <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#F58E34" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="5" fill="#F58E34"/>
                <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
             </svg>
          </div>
          <span class="name">ZUHR</span>
          <span class="time-val" id="pt-dhuhr">1:30pm</span>
        </div>

        <!-- Asr -->
        <div class="time-item" data-prayer="Asr">
          <div class="icon">
             <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#F58E34" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="10" r="4" fill="#F58E34"/>
                <path d="M12 1v2M18.36 4.64l-1.42 1.42M21 10h-2M5.64 4.64l1.42 1.42M3 10h2"/>
                <path d="M5 16l7 3 7-3" stroke="#2e7d32"/>
                <path d="M3 20h18" stroke="#2e7d32"/>
             </svg>
          </div>
          <span class="name">ASR</span>
          <span class="time-val" id="pt-asr">4:30pm</span>
        </div>

        <!-- Maghrib -->
        <div class="time-item" data-prayer="Maghrib">
          <div class="icon">
             <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#F58E34" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="10" cy="12" r="5" fill="#F58E34"/>
                <path d="M10 3v2M17.07 4.93l-1.41 1.41M4.34 6.34L2.93 4.93M20 12h2M2 12H0"/>
                <path d="M13 16c0-1.66 1.34-3 3-3s3 1.34 3 3H8" stroke="#2e7d32"/>
                <circle cx="16" cy="16" r="2" fill="#2e7d32" stroke="none"/>
             </svg>
          </div>
          <span class="name">MAGHRIB</span>
          <span class="time-val" id="pt-maghrib">6:00pm</span>
        </div>

        <!-- Isha -->
        <div class="time-item" data-prayer="Isha">
          <div class="icon">
             <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="none">
                <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79Z" fill="#2e7d32"/>
                <path d="M18 6L18.5 4.5L20 4L18.5 3.5L18 2L17.5 3.5L16 4L17.5 4.5L18 6Z" fill="#F58E34"/>
             </svg>
          </div>
          <span class="name">ISHA</span>
          <span class="time-val" id="pt-isha">8:00pm</span>
        </div>

      </div>
    </div>
  </div>
</div>

<style>
  .prayer-times-wrapper {
    position: relative;
    width: 100%;
    margin: 0 auto;
    background: #FAFCFA;
    border-radius: 20px;
    box-shadow: 0 4px 30px rgba(0,0,0,0.04);
    overflow: hidden; /* Ensures background arts stay inside the card */
    min-height: 240px;
    display: flex;
    align-items: center;
    font-family: system-ui, -apple-system, sans-serif;
    z-index: 1;
  }

  /* --- Background Arts --- */
  .deco-mandala {
    position: absolute;
    top: -30px;
    right: -30px;
    width: 250px;
    height: 250px;
    z-index: -1;
    pointer-events: none;
  }
  .deco-mandala svg { width: 100%; height: 100%; }

  .deco-landscape {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 140px;
    z-index: -1;
    pointer-events: none;
  }
  .deco-landscape svg { width: 100%; height: 100%; }


  /* --- Content Layout --- */
  .prayer-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    padding: 30px 40px;
    gap: 40px;
    z-index: 2; /* keep text above backgrounds */
  }

  /* Left Col */
  .location-col {
    flex: 1;
    min-width: 200px;
  }
  .location-col .city {
    font-size: 28px;
    font-weight: 800;
    color: #1b5e20;
    margin: 0;
    line-height: 1.2;
  }
  .location-col .country {
    font-size: 18px;
    font-weight: 600;
    color: #388e3c;
    margin: 4px 0 0 0;
  }

  /* Right Col */
  .times-col {
    flex: 2;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  
  .times-header {
    display: flex;
    align-items: baseline;
    gap: 12px;
  }
  .times-header .title {
    font-size: 22px;
    font-weight: 800;
    color: #1b5e20;
    margin: 0;
  }
  .sunrise-info {
    margin: 0;
    font-size: 15px;
    font-weight: 700;
  }
  .sunrise-info .time { color: #F58E34; }
  .sunrise-info .label { color: #2e7d32; }

  /* Grid for Times */
  .times-grid {
    display: flex;
    gap: 24px;
    flex-wrap: wrap; /* Allows wrapping on smaller screens */
  }

  .time-item {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 6px;
  }
  
  .time-item .icon {
    height: 32px;
    display: flex;
    align-items: center;
  }

  .time-item .name {
    font-size: 12px;
    font-weight: 700;
    color: #388e3c;
    letter-spacing: 0.5px;
    text-transform: uppercase;
  }

  .time-item .time-val {
    font-size: 16px;
    font-weight: 800;
    color: #4caf50;
  }

  /* --- Responsive Mobile View --- */
  @media (max-width: 900px) {
    .prayer-content {
      padding: 30px;
      gap: 20px;
    }
    .deco-mandala {
      width: 180px;
      height: 180px;
      opacity: 0.2; /* Fade it out so it doesn't distract */
    }
  }

  @media (max-width: 600px) {
    .prayer-times-wrapper {
      flex-direction: column;
      align-items: flex-start;
      min-height: auto;
    }
    
    .prayer-content {
      flex-direction: column;
      align-items: flex-start;
      padding: 24px;
      background: rgba(255, 255, 255, 0.6); /* Slight white overlay for readability */
      backdrop-filter: blur(2px);
      border-radius: 20px;
    }

    .deco-landscape {
      height: 120px;
      opacity: 0.5; /* Fade landscape on mobile so text is legible */
    }

    .times-grid {
      gap: 16px;
      justify-content: flex-start;
      width: 100%;
    }

    .location-col .city {
      font-size: 24px;
    }

    .time-item {
      align-items: center; /* Center them on mobile for better grid look */
      flex: 1 1 calc(33% - 16px); /* 3 items per row on mobile */
    }

    .time-item .time-val {
      font-size: 14px;
    }
  }
</style>