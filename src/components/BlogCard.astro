---
interface Props {
  image?: string;
  date: string;
  category: string;
  title: string;
  excerpt: string;
  href?: string;
}

const { image, date, category, title, excerpt, href = '#' } = Astro.props;

// Category → image mapping
const categoryImages: Record<string, string> = {
  'রুকইয়াহ':       '/images/categories/cat_ruqyah.jpg',
  'যাদু':           '/images/categories/cat_jadu.jpg',
  'বদনজর':          '/images/categories/cat_badnazar.jpg',
  'হাসাদ':          '/images/categories/cat_badnazar.jpg',
  'জ্বীন':           '/images/categories/cat_jinn.jpg',
  'দোয়া ও আমল':   '/images/categories/cat_dua.jpg',
  'মাসনুন দোয়া':   '/images/categories/cat_dua.jpg',
  'মাসনূন দোয়া':   '/images/categories/cat_dua.jpg',
  'ফাতওয়া':        '/images/categories/cat_fatwa.jpg',
  'তাফসীর':        '/images/categories/cat_fatwa.jpg',
  'আয়াত লিস্ট':   '/images/categories/cat_fatwa.jpg',
  'ওয়াসওয়াসা':    '/images/categories/cat_mental.jpg',
  'মানসিক রোগ':    '/images/categories/cat_mental.jpg',
  'বাচ্চাদের রুকইয়াহ': '/images/categories/cat_ruqyah.jpg',
  'হেফাজত':        '/images/categories/cat_ruqyah.jpg',
  'তিব্বে নববী':   '/images/categories/cat_dua.jpg',
  'বিবাহ':          '/images/categories/cat_default.jpg',
};

const resolvedImage = image
  ?? categoryImages[category]
  ?? '/images/categories/cat_default.jpg';
---

<a href={href} class="blog-card">
  <div class="blog-img-wrap">
    <img
      src={resolvedImage}
      alt={title}
      loading="lazy"
      decoding="async"
      fetchpriority="low"
      width="800"
      height="420"
    />
    <span class="blog-category">{category}</span>
  </div>
  <div class="blog-body">
    <p class="blog-date">{date}</p>
    <h3 class="blog-title">{title}</h3>
    <p class="blog-excerpt">{excerpt}</p>
    <span class="read-more">বিস্তারিত পড়ুন →</span>
  </div>
</a>

<style>
.blog-card {
  display: flex;
  flex-direction: column;
  background: var(--bg-white);
  border-radius: var(--radius-md);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
  border: 1px solid var(--border);
  transition: transform 0.25s, box-shadow 0.25s;
  text-decoration: none;
  color: inherit;
}
.blog-card:hover {
  transform: translateY(-5px);
  box-shadow: var(--shadow-lg);
}

/* Image */
.blog-img-wrap {
  position: relative;
  overflow: hidden;
  height: 200px;
  background: var(--dark-section);
}
.blog-img-wrap img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.4s ease;
  display: block;
}
.blog-card:hover .blog-img-wrap img {
  transform: scale(1.06);
}

/* Category badge */
.blog-category {
  position: absolute;
  top: 12px;
  left: 12px;
  background: var(--primary);
  color: #fff;
  font-size: 11px;
  font-weight: 700;
  padding: 4px 12px;
  border-radius: 20px;
  letter-spacing: 0.3px;
  box-shadow: 0 2px 8px rgba(16,185,129,0.4);
}

/* Body */
.blog-body {
  padding: 18px 20px 20px;
  display: flex;
  flex-direction: column;
  gap: 6px;
  flex: 1;
}
.blog-date {
  font-size: 12px;
  color: var(--text-muted);
}
.blog-title {
  font-size: 15px;
  font-weight: 700;
  color: var(--text-dark);
  line-height: 1.45;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.blog-excerpt {
  font-size: 13px;
  color: var(--text-medium);
  line-height: 1.6;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  flex: 1;
}
.read-more {
  font-size: 13px;
  color: var(--primary);
  font-weight: 600;
  margin-top: 4px;
}
</style>
