---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import {
  beforeYouBookChecklist,
  clinicNumbers,
  clinicSchedule,
  getWhatsappUrl,
  primaryContact,
} from '../data/clinic.js';
---

<BaseLayout title="রাকী পরিচয় ও যোগাযোগ | Ruqyah Healing Center" description="রাকী টিমের সাথে যোগাযোগ, সময়সূচী ও বুকিং নির্দেশনা।">
  <Header />

  <main class="team-page">
    <section class="team-hero">
      <div class="container team-layout">
        <div class="team-copy">
          <span class="eyebrow">রাকী ও সেবা সমন্বয়</span>
          <h1>বিশেষজ্ঞ রাকীদের সাথে পরামর্শের জন্য সরাসরি যোগাযোগ করুন</h1>
          <p>
            আমাদের টিম রোগীর অবস্থা, সেবা ধরন এবং সময়সূচী অনুযায়ী উপযুক্ত সেশন সমন্বয় করে থাকে।
            অ্যাপয়েন্টমেন্ট ফর্ম পূরণের পাশাপাশি জরুরি প্রয়োজনে সরাসরি WhatsApp-এ যোগাযোগ করতে পারেন।
          </p>

          <div class="cta-row">
            <a
              href={getWhatsappUrl('আসসালামু আলাইকুম, আমি রাকীর সাথে যোগাযোগ করতে চাই।', primaryContact.international)}
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-primary"
            >
              WhatsApp-এ যোগাযোগ করুন
            </a>
            <a href="/appointment" class="btn btn-outline">অ্যাপয়েন্টমেন্ট ফর্মে যান</a>
          </div>
        </div>

        <div class="team-card">
          <h2>যোগাযোগ নাম্বার</h2>
          <div class="phone-list">
            {clinicNumbers.map((contact) => (
              <div class="phone-item">
                <div>
                  <p class="phone-label">{contact.label}</p>
                  <a href={`tel:${contact.display}`} class="phone-number">{contact.display}</a>
                </div>
                <a
                  href={getWhatsappUrl('আসসালামু আলাইকুম, আমি রাকীর সাথে যোগাযোগ করতে চাই।', contact.international)}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="phone-wa"
                >
                  WhatsApp
                </a>
              </div>
            ))}
          </div>

          <div class="schedule-box">
            <h3>সময়সূচী</h3>
            <p>{clinicSchedule.days}</p>
            <p>{clinicSchedule.hours}</p>
          </div>
        </div>
      </div>
    </section>

    <section class="team-rules">
      <div class="container">
        <div class="rules-card">
          <h2>Before You Book</h2>
          <ul class="rules-list">
            {beforeYouBookChecklist.map((item) => <li>{item}</li>)}
          </ul>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
.team-page {
  background: linear-gradient(180deg, #f6fff9 0%, #f2fcf6 100%);
}

.team-hero {
  padding: 56px 0 32px;
}

.team-layout {
  display: grid;
  grid-template-columns: minmax(0, 1.3fr) 380px;
  gap: 28px;
  align-items: start;
}

.team-copy,
.team-card,
.rules-card {
  background: rgba(255, 255, 255, 0.96);
  border: 1px solid rgba(16, 185, 129, 0.15);
  border-radius: 24px;
  box-shadow: var(--shadow-sm);
}

.team-copy {
  padding: 32px;
}

.eyebrow {
  display: inline-flex;
  font-size: 13px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.04em;
  color: var(--primary-dark);
}

.team-copy h1 {
  font-size: clamp(30px, 5vw, 46px);
  line-height: 1.15;
  margin: 12px 0 16px;
}

.team-copy p,
.team-card p,
.rules-list li {
  color: var(--text-medium);
  line-height: 1.75;
}

.cta-row {
  display: flex;
  gap: 14px;
  flex-wrap: wrap;
  margin-top: 26px;
}

.team-card,
.rules-card {
  padding: 28px;
}

.team-card h2,
.rules-card h2 {
  font-size: 26px;
  margin-bottom: 18px;
}

.phone-list {
  display: flex;
  flex-direction: column;
  gap: 14px;
}

.phone-item {
  display: flex;
  justify-content: space-between;
  gap: 16px;
  align-items: center;
  padding: 16px;
  border-radius: 18px;
  border: 1px solid var(--border);
  background: #fbfffd;
}

.phone-label {
  font-size: 12px;
  font-weight: 700;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.04em;
}

.phone-number {
  font-size: 20px;
  font-weight: 700;
  color: var(--text-dark);
}

.phone-wa {
  padding: 10px 14px;
  border-radius: 999px;
  background: #22c55e;
  color: #fff;
  font-weight: 700;
  font-size: 13px;
}

.schedule-box {
  margin-top: 18px;
  padding: 18px;
  border-radius: 18px;
  background: var(--primary-light);
}

.schedule-box h3 {
  font-size: 18px;
  margin-bottom: 8px;
}

.team-rules {
  padding: 0 0 72px;
}

.rules-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.rules-list li {
  position: relative;
  padding-left: 18px;
}

.rules-list li::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0.72em;
  width: 7px;
  height: 7px;
  border-radius: 50%;
  background: var(--primary);
  transform: translateY(-50%);
}

@media (max-width: 920px) {
  .team-layout {
    grid-template-columns: 1fr;
  }
}

@media (max-width: 640px) {
  .team-copy,
  .team-card,
  .rules-card {
    padding: 22px 18px;
  }

  .phone-item {
    flex-direction: column;
    align-items: flex-start;
  }

  .team-copy h1,
  .team-card h2,
  .rules-card h2 {
    font-size: 24px;
  }
}
</style>
