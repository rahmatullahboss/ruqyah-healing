---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((post) => ({
    params: { slug: post.id.replace(/\.md$/, '') },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

// Related posts (same category, excluding current)
const allPosts = await getCollection('posts');
const related = allPosts
  .filter((p) => p.data.category === post.data.category && p.id !== post.id)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);

// Reading time (approx: 150 words/min for Bengali)
const contentText = post.body ?? '';
const wordCount   = contentText.split(/\s+/).length;
const readingTime = Math.max(1, Math.ceil(wordCount / 150));

// JSON-LD BlogPosting schema
const siteUrl   = 'https://ruqyah-healing.pages.dev';
const postUrl   = `${siteUrl}/posts/${post.id.replace(/\.md$/, '')}`;
const jsonLd = {
  '@context': 'https://schema.org',
  '@type':    'BlogPosting',
  headline:   post.data.title,
  description: post.data.excerpt,
  url:          postUrl,
  datePublished: post.data.date,
  dateModified:  post.data.date,
  inLanguage:    'bn-BD',
  author: {
    '@type': 'Person',
    name:    'মুফতী মুহাম্মাদ আল-আমীন',
    url:     `${siteUrl}/profile`,
  },
  publisher: {
    '@type': 'Organization',
    name:    'রুকইয়াহ হিলিং সেন্টার',
    url:     siteUrl,
    logo: {
      '@type': 'ImageObject',
      url:     `${siteUrl}/favicon.svg`,
    },
  },
  keywords: post.data.tags.join(', '),
  articleSection: post.data.category,
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id':   postUrl,
  },
};

// BreadcrumbList schema
const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type':    'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'হোম',  item: siteUrl },
    { '@type': 'ListItem', position: 2, name: 'ব্লগ', item: `${siteUrl}/blog` },
    { '@type': 'ListItem', position: 3, name: post.data.category, item: `${siteUrl}/category/${post.data.category}` },
    { '@type': 'ListItem', position: 4, name: post.data.title, item: postUrl },
  ],
};

const formattedDate = new Date(post.data.date).toLocaleDateString('bn-BD', {
  year: 'numeric', month: 'long', day: 'numeric',
});
---

<BaseLayout
  title={`${post.data.title} | রুকইয়াহ হিলিং`}
  description={post.data.excerpt}
  ogType="article"
  articleDate={post.data.date}
  articleSection={post.data.category}
  keywords={post.data.tags}
>
  <!-- JSON-LD injected into <head> via named slot -->
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />

  <Header />

  <!-- Post Hero -->
  <section class="post-hero">
    <div class="container">
      <nav class="breadcrumb" aria-label="breadcrumb">
        <a href="/">হোম</a>
        <span aria-hidden="true">›</span>
        <a href="/blog">ব্লগ</a>
        <span aria-hidden="true">›</span>
        <a href={`/category/${post.data.category}`}>{post.data.category}</a>
      </nav>
      <span class="cat-badge">{post.data.category}</span>
      <h1>{post.data.title}</h1>
      <div class="post-meta-row">
        <time datetime={post.data.date} class="post-date">
          🗓 {formattedDate}
        </time>
        <span class="reading-time">🕐 {readingTime} মিনিট পড়া</span>
        <span class="word-count">📝 ~{wordCount} শব্দ</span>
      </div>
      <p class="post-excerpt">{post.data.excerpt}</p>
    </div>
  </section>

  <!-- Article Content -->
  <section class="section-sm">
    <div class="container post-layout">
      <article class="prose" id="post-content" itemscope itemtype="https://schema.org/BlogPosting">
        <meta itemprop="headline" content={post.data.title} />
        <meta itemprop="datePublished" content={post.data.date} />
        <Content />
      </article>

      <!-- Tags -->
      {post.data.tags.length > 0 && (
        <div class="post-tags">
          <strong>ট্যাগ:</strong>
          {post.data.tags.map((tag) => (
            <span class="tag">#{tag}</span>
          ))}
        </div>
      )}

      <!-- Share nudge -->
      <div class="share-bar">
        <span>এই পোস্টটি উপকারী মনে হলে শেয়ার করুন 🤲</span>
      </div>
    </div>
  </section>

  <!-- Related Posts -->
  {related.length > 0 && (
    <section class="section-sm related-section">
      <div class="container">
        <h2 class="related-title">আরও পড়ুন</h2>
        <div class="grid-3">
          {related.map((rel) => (
            <a href={`/posts/${rel.id.replace(/\.md$/, '')}`} class="rel-card">
              <span class="cat-badge small">{rel.data.category}</span>
              <h3>{rel.data.title}</h3>
              <p>{rel.data.excerpt.substring(0, 100)}…</p>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <Footer />
</BaseLayout>

<style>
  /* Hero */
  .post-hero {
    background: linear-gradient(135deg, var(--dark-section) 0%, #065f46 100%);
    color: #fff;
    padding: 64px 0 56px;
  }
  .post-hero .breadcrumb {
    display: flex;
    gap: 8px;
    align-items: center;
    color: rgba(255,255,255,0.55);
    font-size: 13px;
    margin-bottom: 20px;
  }
  .post-hero .breadcrumb a { color: rgba(255,255,255,0.65); }
  .post-hero .breadcrumb a:hover { color: #fff; }
  .post-hero .cat-badge {
    background: rgba(255,255,255,0.15);
    color: #fff;
    margin-bottom: 16px;
    display: inline-block;
    font-size: 12px;
    font-weight: 600;
    padding: 4px 14px;
    border-radius: 20px;
    letter-spacing: 0.5px;
  }
  .post-hero h1 {
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    font-weight: 800;
    line-height: 1.3;
    margin: 12px 0 16px;
    max-width: 780px;
  }
  .post-meta-row {
    display: flex;
    gap: 20px;
    flex-wrap: wrap;
    align-items: center;
    font-size: 13px;
    color: rgba(255,255,255,0.55);
    margin-bottom: 20px;
  }
  .post-excerpt {
    color: rgba(255,255,255,0.75);
    font-size: 16px;
    max-width: 680px;
    line-height: 1.7;
  }

  /* Layout */
  .post-layout { max-width: 780px; }

  /* Tags */
  .post-tags {
    margin-top: 40px;
    padding-top: 24px;
    border-top: 1px solid var(--border);
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: center;
    font-size: 14px;
    color: var(--text-muted);
  }
  .tag {
    background: var(--bg-light);
    border: 1px solid var(--border);
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 13px;
    color: var(--primary-dark);
    font-weight: 500;
  }

  /* Share bar */
  .share-bar {
    margin-top: 32px;
    padding: 16px 20px;
    background: var(--primary-light);
    border-radius: var(--radius-md);
    border-left: 4px solid var(--primary);
    font-size: 14px;
    color: var(--primary-dark);
    font-weight: 600;
    text-align: center;
  }

  /* Related */
  .related-section { background: var(--bg-light); }
  .related-title { font-size: 1.4rem; font-weight: 700; margin-bottom: 28px; }
  .rel-card {
    background: var(--bg-white);
    border-radius: var(--radius-md);
    padding: 20px;
    box-shadow: var(--shadow-sm);
    display: block;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    border: 1px solid var(--border);
  }
  .rel-card:hover { transform: translateY(-3px); box-shadow: var(--shadow-md); }
  .rel-card .cat-badge.small {
    font-size: 11px; padding: 3px 10px; margin-bottom: 10px;
    display: inline-block; background: var(--primary-light);
    color: var(--primary-dark); border-radius: 20px;
  }
  .rel-card h3 { font-size: 15px; font-weight: 700; color: var(--text-dark); margin: 8px 0; line-height: 1.4; }
  .rel-card p { font-size: 13px; color: var(--text-muted); line-height: 1.6; }

  @media (max-width: 768px) {
    .post-hero { padding: 48px 0 40px; }
    .post-meta-row { gap: 12px; }
  }
</style>
