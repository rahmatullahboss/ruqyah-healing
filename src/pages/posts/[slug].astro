---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((post) => ({
    // Strip .md extension from id for clean URLs
    params: { slug: post.id.replace(/\.md$/, '') },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

// Related posts (same category, excluding current)
const allPosts = await getCollection('posts');
const related = allPosts
  .filter((p) => p.data.category === post.data.category && p.id !== post.id)
  .slice(0, 3);
---



<BaseLayout title={post.data.title} description={post.data.excerpt}>
  <!-- Hero -->
  <section class="post-hero">
    <div class="container">
      <div class="breadcrumb">
        <a href="/">হোম</a>
        <span>›</span>
        <a href="/blog">ব্লগ</a>
        <span>›</span>
        <span>{post.data.category}</span>
      </div>
      <span class="cat-badge">{post.data.category}</span>
      <h1>{post.data.title}</h1>
      <p class="post-meta">
        <time datetime={post.data.date}>
          {new Date(post.data.date).toLocaleDateString('bn-BD', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
      </p>
      <p class="post-excerpt">{post.data.excerpt}</p>
    </div>
  </section>

  <!-- Content -->
  <section class="section-sm">
    <div class="container post-layout">
      <article class="prose" id="post-content">
        <Content />
      </article>

      <!-- Tags -->
      {post.data.tags.length > 0 && (
        <div class="post-tags">
          <strong>ট্যাগ:</strong>
          {post.data.tags.map((tag) => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      )}
    </div>
  </section>

  <!-- Related Posts -->
  {related.length > 0 && (
    <section class="section-sm related-section">
      <div class="container">
        <h2 class="related-title">আরও পড়ুন</h2>
        <div class="grid-3">
          {related.map((rel) => (
            <a href={`/posts/${rel.slug}`} class="rel-card">
              <span class="cat-badge small">{rel.data.category}</span>
              <h3>{rel.data.title}</h3>
              <p>{rel.data.excerpt.substring(0, 100)}...</p>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>

<style>
  /* Hero */
  .post-hero {
    background: linear-gradient(135deg, var(--dark-section) 0%, #0d3060 100%);
    color: #fff;
    padding: 64px 0 56px;
  }
  .post-hero .breadcrumb { color: rgba(255,255,255,0.6); margin-bottom: 20px; }
  .post-hero .breadcrumb a { color: rgba(255,255,255,0.6); }
  .post-hero .breadcrumb a:hover { color: #fff; }
  .post-hero .cat-badge {
    background: rgba(255,255,255,0.15);
    color: #fff;
    margin-bottom: 16px;
  }
  .post-hero h1 {
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    font-weight: 800;
    line-height: 1.3;
    margin: 12px 0 16px;
    max-width: 780px;
  }
  .post-meta { color: rgba(255,255,255,0.5); font-size: 14px; margin-bottom: 16px; }
  .post-excerpt {
    color: rgba(255,255,255,0.75);
    font-size: 16px;
    max-width: 680px;
    line-height: 1.7;
  }

  /* Layout */
  .post-layout { max-width: 780px; }

  /* Tags */
  .post-tags {
    margin-top: 40px;
    padding-top: 24px;
    border-top: 1px solid var(--border);
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: center;
    font-size: 14px;
    color: var(--text-muted);
  }
  .tag {
    background: var(--bg-light);
    border: 1px solid var(--border);
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 13px;
    color: var(--text-medium);
  }

  /* Related */
  .related-section { background: var(--bg-light); }
  .related-title { font-size: 1.4rem; font-weight: 700; margin-bottom: 28px; }
  .rel-card {
    background: #fff;
    border-radius: var(--radius-md);
    padding: 20px;
    box-shadow: var(--shadow-sm);
    display: block;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    border: 1px solid var(--border);
  }
  .rel-card:hover { transform: translateY(-3px); box-shadow: var(--shadow-md); }
  .rel-card .cat-badge.small { font-size: 11px; padding: 3px 10px; margin-bottom: 10px; display: inline-block; }
  .rel-card h3 { font-size: 15px; font-weight: 700; color: var(--text-dark); margin: 8px 0; line-height: 1.4; }
  .rel-card p { font-size: 13px; color: var(--text-muted); line-height: 1.6; }

  @media (max-width: 768px) {
    .post-hero { padding: 48px 0 40px; }
  }
</style>
