---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { testCategories, kidsQuestions, answerOptions, type TestCategory } from '../../data/test-data';

export function getStaticPaths() {
  return testCategories.map(cat => ({ params: { testId: cat.id } }));
}

const { testId } = Astro.params;
const category = testCategories.find(c => c.id === testId) as TestCategory;

// For non-kids, embed questions directly; kids uses client-side switching
const isKids = testId === 'kids';
const questions = isKids ? [] : category.questions;
---

<BaseLayout
  title={`${category.title} | রুকইয়াহ হিলিং সেন্টার`}
  description={category.description}
>
  <Header />

  <main>
    <!-- Breadcrumb -->
    <div class="page-header">
      <div class="container">
        <nav class="breadcrumb" aria-label="breadcrumb">
          <a href="/">হোম</a>
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
          <a href="/ruqyah-test">সেলফ রুকইয়াহ টেস্ট</a>
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
          <span>{category.title}</span>
        </nav>
      </div>
    </div>

    <!-- Kids Age Selector (only for kids test) -->
    {isKids && (
      <section class="age-selector-section" id="ageSelectorSection">
        <div class="container">
          <div class="age-selector-card">
            <div class="test-icon" style={`background:${category.colorLight}`}>{category.icon}</div>
            <h1>{category.title}</h1>
            <p class="test-desc">{category.description}</p>
            <p style="font-weight:700; color: var(--text-dark); margin-bottom: 16px;">শিশুর বয়স বেছে নিন:</p>
            <div class="age-btns">
              <button class="age-btn" id="btnInfant" onclick="selectAgeGroup('infant')">
                <span class="age-icon">👶</span>
                <span class="age-label">০ – ২ বছর</span>
                <span class="age-sub">৬টি প্রশ্ন</span>
              </button>
              <button class="age-btn" id="btnChild" onclick="selectAgeGroup('child')">
                <span class="age-icon">🧒</span>
                <span class="age-label">২ – ১২ বছর</span>
                <span class="age-sub">১৯টি প্রশ্ন</span>
              </button>
            </div>
          </div>
        </div>
      </section>
    )}

    <!-- Quiz Section -->
    <section class="quiz-section" id="quizSection" class:list={[isKids && 'hidden']}>
      <div class="container">
        <!-- Test intro header -->
        <div class="test-intro" id="testIntro">
          <div class="test-icon-sm" style={`background:${category.colorLight}`}>{category.icon}</div>
          <div>
            <p class="intro-sub" style={`color:${category.color}`}>{category.subtitle}</p>
            <h1 class="intro-title">{category.title}</h1>
          </div>
        </div>

        <div class="quiz-wrapper">
          <!-- Progress -->
          <div class="quiz-progress">
            <div class="progress-top">
              <span class="progress-label" id="progressLabel">প্রশ্ন ১ / ?</span>
              <span class="progress-percent" id="progressPercent">০% সম্পন্ন</span>
            </div>
            <div class="progress-bar" role="progressbar" aria-valuemin={0} aria-valuemax={100} aria-valuenow={0}>
              <div class="progress-fill" id="progressFill" style={`width:0%;background:${category.color}`}></div>
            </div>
          </div>

          <!-- Question Card -->
          <div class="question-card" id="questionCard">
            <div class="question-num-badge" id="questionNumBadge" style={`background:${category.colorLight};color:${category.color}`}>প্রশ্ন ১</div>
            <h2 id="questionText">লোড হচ্ছে...</h2>

            <!-- Answers -->
            <div class="answer-options" id="answerOptions">
              {answerOptions.map(opt => (
                <button
                  class="answer-btn"
                  data-value={opt.value}
                  style={`--opt-bg:${opt.color};--opt-text:${opt.text}`}
                  onclick={`selectAnswer(${opt.value})`}
                >
                  <span class="opt-emoji">
                    {opt.value === 2 ? '✅' : opt.value === 1 ? '🤔' : '❌'}
                  </span>
                  <span class="opt-label">{opt.label}</span>
                </button>
              ))}
            </div>

            <!-- Navigation -->
            <div class="quiz-nav">
              <button class="nav-btn prev-btn" id="prevBtn" onclick="prevQuestion()" disabled>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6"/></svg>
                পূর্ববর্তী
              </button>
              <div class="dots" id="dotsContainer"></div>
              <button class="nav-btn next-btn" id="nextBtn" onclick="nextQuestion()" style={`color:${category.color}`}>
                পরবর্তী
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
              </button>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Result Section -->
    <section class="result-section hidden" id="resultSection">
      <div class="container">
        <div class="result-card" id="resultCard">
          <!-- dynamically built by showResult() -->
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<!-- Pass data to client -->
<script define:vars={{
  categoryId: category.id,
  categoryTitle: category.title,
  categoryColor: category.color,
  isKids,
  serverQuestions: questions,
  infantQs: kidsQuestions.infant,
  childQs: kidsQuestions.child,
  resultLow:  category.getResult(0),
  resultMed:  category.getResult(30),
  resultHigh: category.getResult(60),
  categoryGetResultThresholds: { low: 30, high: 55 },
}}>

// ── State ───────────────────────────────────────────────────────────────────
let questions  = isKids ? [] : serverQuestions;
let answers    = [];
let currentQ   = 0;

// ── Kids Age Selection ────────────────────────────────────────────────────────
window.selectAgeGroup = function(group) {
  questions = group === 'infant' ? infantQs : childQs;
  answers   = new Array(questions.length).fill(null);
  currentQ  = 0;
  document.getElementById('ageSelectorSection')?.classList.add('hidden');
  const quizSection = document.getElementById('quizSection');
  quizSection?.classList.remove('hidden');
  updateUI();
};

// ── UI Update ─────────────────────────────────────────────────────────────────
function updateUI(animate = false) {
  if (questions.length === 0) return;
  const q   = questions[currentQ];
  const len = questions.length;

  const textEl    = document.getElementById('questionText');
  const labelEl   = document.getElementById('progressLabel');
  const pctEl     = document.getElementById('progressPercent');
  const fillEl    = document.getElementById('progressFill');
  const numBadge  = document.getElementById('questionNumBadge');
  const prevBtn   = document.getElementById('prevBtn');
  const nextBtn   = document.getElementById('nextBtn');
  const pBar      = document.querySelector('.progress-bar');
  const pct       = Math.round(((currentQ + 1) / len) * 100);

  if (textEl) {
    if (animate) {
      textEl.style.opacity = '0';
      textEl.style.transform = 'translateY(10px)';
      setTimeout(() => {
        textEl.textContent = q.text;
        textEl.style.transition = 'opacity 0.22s, transform 0.22s';
        textEl.style.opacity = '1';
        textEl.style.transform = 'translateY(0)';
      }, 140);
    } else {
      textEl.textContent = q.text;
    }
  }

  if (numBadge) numBadge.textContent = `প্রশ্ন ${currentQ + 1}`;
  if (labelEl)  labelEl.textContent  = `প্রশ্ন ${currentQ + 1} / ${len}`;
  if (pctEl)    pctEl.textContent    = `${pct}% সম্পন্ন`;
  if (fillEl)   fillEl.style.width   = `${pct}%`;
  if (pBar)     pBar.setAttribute('aria-valuenow', pct.toString());

  // Highlight selected answer
  document.querySelectorAll('.answer-btn').forEach(btn => {
    const val = parseInt(btn.dataset.value ?? '-1');
    btn.classList.toggle('selected', answers[currentQ] === val);
  });

  if (prevBtn) prevBtn.disabled = currentQ === 0;
  buildDots();
}

// ── Dots ─────────────────────────────────────────────────────────────────────
function buildDots() {
  const container = document.getElementById('dotsContainer');
  if (!container) return;
  // Only show max 20 dots; otherwise show fraction text
  if (questions.length > 20) {
    container.innerHTML = `<span style="font-size:13px;color:var(--text-muted)">${currentQ + 1} / ${questions.length}</span>`;
    return;
  }
  container.innerHTML = '';
  answers.forEach((ans, i) => {
    const dot = document.createElement('span');
    dot.className = 'dot' + (ans !== null ? ' answered' : '') + (i === currentQ ? ' current' : '');
    if (i === currentQ) dot.style.background = categoryColor;
    else if (ans !== null) dot.style.background = '#22c55e';
    container.appendChild(dot);
  });
}

// ── Answer Selection ──────────────────────────────────────────────────────────
window.selectAnswer = function(val) {
  if (questions.length === 0) return;
  answers[currentQ] = val;
  updateUI();
  setTimeout(() => {
    if (currentQ < questions.length - 1) {
      currentQ++;
      updateUI(true);
    } else {
      showResult();
    }
  }, 380);
};

window.nextQuestion = function() {
  if (currentQ < questions.length - 1) { currentQ++; updateUI(true); }
  else showResult();
};
window.prevQuestion = function() {
  if (currentQ > 0) { currentQ--; updateUI(true); }
};

// ── Result ────────────────────────────────────────────────────────────────────
function calcResult() {
  const maxScore = questions.length * 2;
  const totalScore = answers.reduce((sum, a) => sum + (a ?? 0), 0);
  const pct = maxScore === 0 ? 0 : Math.round((totalScore / maxScore) * 100);
  const yesCount    = answers.filter(a => a === 2).length;
  const maybeCount  = answers.filter(a => a === 1).length;
  const noCount     = answers.filter(a => a === 0).length;
  return { pct, yesCount, maybeCount, noCount, totalQ: questions.length };
}

function getResultForPct(pct) {
  if (pct >= categoryGetResultThresholds.high) return resultHigh;
  if (pct >= categoryGetResultThresholds.low)  return resultMed;
  return resultLow;
}

// ── Answer label helpers ──────────────────────────────────────────────────────
function answerLabel(val) {
  if (val === 2) return 'হ্যাঁ';
  if (val === 1) return 'মাঝে মধ্যে';
  return 'না';
}

// ── Protocol HTML builder ─────────────────────────────────────────────────────
function buildProtocolHTML(res) {
  if (!res.showProtocol || !res.protocol) return '';
  const p = res.protocol;
  let html = '<div class="rc-protocol">';
  html += `<div class="rc-section-header" style="background:#10b981">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2M9 5a2 2 0 0 0 2 2h2a2 2 0 0 0 2-2M9 5a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2"/></svg>
    করণীয়
  </div>`;

  // custom instruction lines (evil-eye numbered steps)
  if (p.instructions && p.instructions.length) {
    html += '<div class="rc-steps">';
    p.instructions.forEach((line, i) => {
      html += `<div class="rc-step">
        <span class="rc-step-num">${i + 1}</span>
        <span class="rc-step-text">${line}</span>
      </div>`;
    });
    html += '</div>';
  }

  // ingredients
  if (p.ingredients && p.ingredients.length) {
    html += '<div class="rc-subsection">';
    html += '<div class="rc-subsec-title">প্রয়োজনীয় উপকরণ</div><ul class="rc-list">';
    p.ingredients.forEach(item => { html += `<li>${item}</li>`; });
    html += '</ul></div>';
  }

  // tilawat
  if (p.tilawat && p.tilawat.length) {
    html += '<div class="rc-subsection">';
    html += '<div class="rc-subsec-title">তিলাওয়াত ও প্রস্তুতি</div>';
    html += '<p class="rc-note">নিম্নের আয়াতগুলো পড়ুন এবং সবগুলো উপকরণে ফুঁ দিন:</p>';
    html += '<ul class="rc-list">';
    p.tilawat.forEach(t => { html += `<li>${t}</li>`; });
    html += '</ul></div>';
  }

  // effects
  if (p.effects && p.effects.length) {
    html += '<div class="rc-subsection">';
    html += '<div class="rc-subsec-title">সম্ভাব্য প্রভাব ও পরামর্শ</div><ul class="rc-list">';
    p.effects.forEach(e => { html += `<li>${e}</li>`; });
    html += '</ul></div>';
  }

  // tabeez warning
  if (p.tabeejWarning) {
    html += `<div class="rc-warning">
      <span class="rc-warning-icon">⚠️</span>
      <span>আপনি যদি তাবিজ ব্যবহার করে থাকেন বা বর্তমানে তাবিজ কাছে থাকে, তবে অবশ্যই রুকইয়াহ শুরু করার আগে সেই তাবিজ নষ্ট করতে হবে। <a href="/posts/tabij-nosto-korar-niyom" style="font-weight:700;text-decoration:underline;white-space:nowrap">তাবিজ নষ্টের নিয়ম পড়ুন →</a></span>
    </div>`;
  }

  html += '</div>';
  return html;
}

// ── Answered questions list ───────────────────────────────────────────────────
function buildProblemsHTML() {
  const answered = [];
  answers.forEach((val, i) => {
    if (val === 2 || val === 1) {
      answered.push({ val, q: questions[i], idx: i });
    }
  });

  if (!answered.length) return '';

  let html = '<div class="rc-problems">';
  html += `<div class="rc-section-header" style="background:#6366f1">
    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
    আপনার সমস্যাসমূহ
  </div>`;
  html += '<div class="rc-badges">';
  answered.forEach(({ val, q, idx }) => {
    const cls = val === 2 ? 'rc-badge-yes' : 'rc-badge-maybe';
    const tag = val === 2 ? 'হ্যাঁ' : 'মাঝে মধ্যে';
    html += `<div class="rc-badge-item ${cls}">
      <span class="rc-badge-num">${idx + 1}</span>
      <span class="rc-badge-text">${q.text}</span>
      <span class="rc-badge-tag">${tag}</span>
    </div>`;
  });
  html += '</div></div>';
  return html;
}

function showResult() {
  document.getElementById('quizSection')?.classList.add('hidden');
  const rs = document.getElementById('resultSection');
  rs?.classList.remove('hidden');
  rs?.scrollIntoView({ behavior: 'smooth', block: 'start' });

  const { pct, yesCount, maybeCount, noCount, totalQ } = calcResult();
  const res = getResultForPct(pct);

  function toBengaliNum(n) {
    return n.toString().replace(/[0-9]/g, d => '০১২৩৪৫৬৭৮৯'[d]);
  }

  // Build primary / secondary button HTML
  const actionsHTML = res.actions.map((a, i) => {
    const cls = i === 0 ? 'rc-btn-primary' : 'rc-btn-secondary';
    return `<a href="${a.href}" class="${cls}">${a.label}</a>`;
  }).join('');

  const card = document.getElementById('resultCard');
  if (!card) return;

  const pctNum = pct;
  const gaugeStroke = res.level === 'high' ? '#dc2626'
                    : res.level === 'medium' ? '#f59e0b' : '#10b981';
  const levelBg = res.level === 'high'   ? '#fef2f2'
                : res.level === 'medium' ? '#fffbeb' : '#f0fdf4';
  const levelColor = res.level === 'high'   ? '#dc2626'
                   : res.level === 'medium' ? '#d97706' : '#15803d';
  const resultBoxBg = res.level === 'high'   ? 'border-left-color:#dc2626;background:#fef2f2'
                    : res.level === 'medium' ? 'border-left-color:#f59e0b;background:#fffbeb' : 'border-left-color:#10b981;background:#f0fdf4';

  const gaugeHTML = `
  <svg class="risk-gauge" width="140" height="100" viewBox="0 0 140 100">
    <path d="M 14 90 A 56 56 0 0 1 126 90" fill="none" stroke="#e5e7eb" stroke-width="10" stroke-linecap="round"/>
    <path d="M 14 90 A 56 56 0 0 1 126 90" fill="none" stroke="${gaugeStroke}" stroke-width="10"
      stroke-linecap="round"
      stroke-dasharray="${(pctNum / 100 * 175.9).toFixed(1)} 175.9"
      style="transition:stroke-dasharray 1s ease"/>
    <text x="70" y="80" text-anchor="middle" font-size="24" font-weight="800" fill="${gaugeStroke}" font-family="inherit">${toBengaliNum(pctNum)}%</text>
  </svg>`;

  card.innerHTML = `
    <div class="rc-header">
      <div class="rc-gauge-wrap">
        ${gaugeHTML}
        <span class="rc-level-badge" style="background:${levelBg};color:${levelColor};border:1.5px solid ${gaugeStroke}40">${res.label}</span>
      </div>
      <h2 class="rc-main-title">পরীক্ষার ফলাফল</h2>
      <div class="rc-meta-chips">
        <span class="rc-chip">${categoryTitle}</span>
        <span class="rc-chip">মোট প্রশ্নঃ ${toBengaliNum(totalQ)}</span>
        ${yesCount   > 0 ? `<span class="rc-chip rc-chip-yes">হ্যাঁঃ ${toBengaliNum(yesCount)}</span>` : ''}
        ${maybeCount > 0 ? `<span class="rc-chip rc-chip-maybe">মাঝে মধ্যেঃ ${toBengaliNum(maybeCount)}</span>` : ''}
        ${noCount    > 0 ? `<span class="rc-chip rc-chip-no">নাঃ ${toBengaliNum(noCount)}</span>` : ''}
      </div>
    </div>

    <div class="rc-result-box" style="${resultBoxBg};color:${levelColor}">
      <span class="rc-result-label">ফলাফল</span>
      <p class="rc-result-text" style="color:#374151">${res.resultText}</p>
    </div>

    ${buildProtocolHTML(res)}
    ${buildProblemsHTML()}

    <div class="rc-actions">${actionsHTML}</div>

    <div class="rc-footer">
      <a href="#" onclick="restartQuiz();return false;">পুনরায় শুরু করুন</a>
      <a href="/ruqyah-test">অন্য টেস্ট দেখুন</a>
    </div>
  `;
}


window.restartQuiz = function() {
  currentQ = 0;
  answers  = new Array(questions.length).fill(null);

  if (isKids) {
    questions = [];
    document.getElementById('resultSection')?.classList.add('hidden');
    document.getElementById('quizSection')?.classList.add('hidden');
    document.getElementById('ageSelectorSection')?.classList.remove('hidden');
  } else {
    document.getElementById('resultSection')?.classList.add('hidden');
    document.getElementById('quizSection')?.classList.remove('hidden');
    updateUI();
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }
};

// ── Init ─────────────────────────────────────────────────────────────────────
if (!isKids) {
  answers = new Array(questions.length).fill(null);
  updateUI();
}
</script>

<style>
/* ── Page Header ── */
.page-header { padding: 14px 0; border-bottom: 1px solid var(--border); }
.breadcrumb { display: flex; gap: 6px; align-items: center; font-size: 14px; color: var(--text-muted); flex-wrap: wrap; }
.breadcrumb a { color: var(--primary); text-decoration: none; }

/* ── Kids Age Selector ── */
.age-selector-section { padding: 60px 0 80px; }
.age-selector-card {
  max-width: 520px; margin: 0 auto; text-align: center;
  background: #fff; border: 1.5px solid var(--border);
  border-radius: 24px; padding: 44px 32px;
  box-shadow: 0 4px 24px rgba(0,0,0,0.06);
}
.test-icon {
  width: 72px; height: 72px; border-radius: 20px; font-size: 32px;
  display: flex; align-items: center; justify-content: center;
  margin: 0 auto 20px;
}
.age-selector-card h1 { font-size: 1.6rem; font-weight: 800; margin-bottom: 12px; }
.test-desc { font-size: 14px; color: var(--text-muted); line-height: 1.6; margin-bottom: 24px; }
.age-btns { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
.age-btn {
  display: flex; flex-direction: column; align-items: center; gap: 6px;
  padding: 20px 12px;
  border: 2px solid var(--border); border-radius: 16px;
  background: #fff; cursor: pointer; font-family: inherit;
  transition: all 0.18s;
}
.age-btn:hover { border-color: var(--primary); background: var(--primary-light); }
.age-icon  { font-size: 28px; }
.age-label { font-size: 15px; font-weight: 700; color: var(--text-dark); }
.age-sub   { font-size: 12px; color: var(--text-muted); }

/* ── Quiz Section ── */
.quiz-section { padding: 40px 0 80px; }
.hidden { display: none !important; }

.test-intro {
  display: flex; align-items: center; gap: 14px;
  max-width: 760px; margin: 0 auto 28px;
}
.test-icon-sm {
  width: 48px; height: 48px; border-radius: 14px; font-size: 22px; flex-shrink: 0;
  display: flex; align-items: center; justify-content: center;
}
.intro-sub  { font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.6px; margin-bottom: 4px; }
.intro-title { font-size: 1.3rem; font-weight: 800; color: var(--text-dark); }

.quiz-wrapper { max-width: 720px; margin: 0 auto; }

/* Progress */
.quiz-progress { margin-bottom: 24px; }
.progress-top { display: flex; justify-content: space-between; font-size: 13px; color: var(--text-muted); margin-bottom: 10px; }
.progress-bar { height: 8px; background: var(--border, #e5e7eb); border-radius: 999px; overflow: hidden; }
.progress-fill { height: 100%; border-radius: 999px; transition: width 0.4s ease; }

/* Question Card */
.question-card {
  background: #fff; border: 1.5px solid var(--border);
  border-radius: 24px; padding: 36px;
  box-shadow: 0 4px 24px rgba(0,0,0,0.06);
}
.question-num-badge {
  display: inline-block; font-size: 12px; font-weight: 700;
  padding: 4px 14px; border-radius: 20px; margin-bottom: 16px;
}
.question-card h2 {
  font-size: clamp(1.05rem, 3vw, 1.35rem); font-weight: 700;
  color: var(--text-dark); margin-bottom: 28px; line-height: 1.55;
}

/* Answers */
.answer-options { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; margin-bottom: 28px; }
.answer-btn {
  display: flex; flex-direction: column; align-items: center; gap: 8px;
  padding: 20px 12px; border: 2px solid var(--border); border-radius: 16px;
  background: #fff; cursor: pointer; transition: all 0.18s;
  font-family: inherit; color: var(--text-dark); min-height: 88px;
}
.answer-btn:hover { border-color: #94a3b8; background: #f8fafc; transform: translateY(-1px); }
.answer-btn.selected {
  border-color: transparent; background: var(--opt-bg, #dcfce7);
  color: var(--opt-text, #16a34a); box-shadow: 0 0 0 2px var(--opt-text, #16a34a);
  transform: translateY(-2px);
}
.opt-emoji { font-size: 22px; }
.opt-label { font-size: 14px; font-weight: 700; }

