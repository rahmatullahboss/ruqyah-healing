}
.nav-btn:hover { color: var(--primary); }
.nav-btn:disabled { opacity: 0.3; cursor: default; }

.dots { display: flex; gap: 5px; flex-wrap: wrap; justify-content: center; max-width: 220px; }
.dot { width: 8px; height: 8px; border-radius: 50%; background: var(--border); transition: background 0.2s, transform 0.2s; }
.dot.current { transform: scale(1.4); }


/* ── Result Section (shell only — content styled by is:global below) ── */
.result-section { padding: 48px 0 80px; }
.result-card {
  max-width: 720px; margin: 0 auto;
  background: #fff; border: 1.5px solid var(--border);
  border-radius: 24px;
