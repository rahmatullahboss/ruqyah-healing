---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import {
  beforeYouBookChecklist,
  bookingInstructions,
  clinicNumbers,
  clinicSchedule,
  getWhatsappUrl,
  paymentDetails,
  paymentMethods,
  postSubmitGuidelines,
  pricingHighlights,
  primaryContact,
  religionOptions,
  serviceModes,
  sessionFormats,
  specialOffers,
  treatmentCatalog,
  durationOptions,
  genderOptions,
} from '../data/clinic.js';

const preferredTimeSlots = [
  'সকাল ৯:০০',
  'সকাল ১০:০০',
  'সকাল ১১:০০',
  'দুপুর ১২:০০',
  'দুপুর ১:০০',
  'দুপুর ২:০০',
  'বিকেল ৩:০০',
  'বিকেল ৪:০০',
  'বিকেল ৫:০০',
  'সন্ধ্যা ৬:০০',
];
---

<BaseLayout
  title="অ্যাপয়েন্টমেন্ট নিন | Ruqyah Healing Center"
  description="রুকইয়াহ, হিজামা, আকুপাংচার, আকুপ্রেসার, ম্যাসাজ ও ন্যাচারোপ্যাথি সেবার জন্য অ্যাপয়েন্টমেন্ট বুক করুন।"
>
  <Header />

  <main class="appt-page">
    <div class="container">
      <div class="breadcrumb">
        <a href="/">হোম</a>
        <span>/</span>
        <span>অ্যাপয়েন্টমেন্ট</span>
      </div>

      <div class="appt-shell">
        <div class="appt-primary">
          <section class="hero-card">
            <div class="hero-copy">
              <span class="eyebrow">রুগীর অ্যাপয়েন্টমেন্ট বুকিং</span>
              <h1>বিশ্বস্ত, অভিজ্ঞ ও বিশেষজ্ঞ রাকীদের সাথে পরামর্শের সুযোগ</h1>
              <p>
                রুকইয়াহ একটি তাওহীদভিত্তিক আধ্যাত্মিক supportive care, যা কুরআন, সুন্নাহ ও জায়েজ দুআর আলোকে পরিচালিত হয়।
                চূড়ান্ত শিফা একমাত্র আল্লাহর পক্ষ থেকেই আসে।
              </p>
            </div>

            <div class="hero-highlights">
              <div class="hero-chip">শিরকমুক্ত ও বিদআত-মুক্ত পদ্ধতি</div>
              <div class="hero-chip">মহিলা রোগীর জন্য মাহরাম বাধ্যতামূলক</div>
              <div class="hero-chip">চেম্বার, হোম সার্ভিস ও অনলাইন সাপোর্ট</div>
              <div class="hero-chip">কোনো 100% cure guarantee দেওয়া হয় না</div>
            </div>
          </section>

          <section class="content-card">
            <div class="section-head">
              <div>
                <span class="section-kicker">সেবার মূল্য তালিকা</span>
                <h2>ডায়াগনোসিস, সেশন ও বুকিং তথ্য</h2>
              </div>
              <p>ঢাকার বাহিরে যাতায়াত খরচ আলাদা এবং অগ্রিম পে করতে হবে। হোম সার্ভিসের সম্পূর্ণ ফি ফোনে আলোচনা সাপেক্ষ।</p>
            </div>

            <div class="pricing-grid">
              {pricingHighlights.map((item) => (
                <article class="pricing-card">
                  <p class="pricing-title">{item.title}</p>
                  <p class="pricing-price">{item.price}</p>
                  <p class="pricing-details">{item.details}</p>
                </article>
              ))}
            </div>

            <div class="offer-box">
              <h3>বিশেষ অফার</h3>
              <ul class="bullet-list">
                {specialOffers.map((offer) => <li>{offer}</li>)}
              </ul>
            </div>
          </section>

          <section class="content-card">
            <div class="section-head">
              <div>
                <span class="section-kicker">চিকিৎসার ধরন</span>
                <h2>প্রয়োজন অনুযায়ী সেবা নির্বাচন করুন</h2>
              </div>
              <p>ফর্মে একটি প্রধান চিকিৎসা বেছে নিলে তার উপযোগী sub-option দেখানো হবে।</p>
            </div>

            <div class="treatment-grid">
              {treatmentCatalog.map((service) => (
                <article class="treatment-card">
                  <h3>{service.label}</h3>
                  <p>{service.summary}</p>
                  <ul class="mini-list">
                    {service.options.slice(0, 4).map((option) => <li>{option}</li>)}
                  </ul>
                </article>
              ))}
            </div>
          </section>

          <section class="content-card" id="booking-form">
            <div class="section-head">
              <div>
                <span class="section-kicker">বুকিং ফর্ম</span>
                <h2>রুগীর অ্যাপয়েন্টমেন্ট তথ্য পূরণ করুন</h2>
              </div>
              <p>সকল তথ্য সততা ও নির্ভুলতার সাথে পূরণ করুন। সঠিক তথ্য প্রদান চিকিৎসার মান নির্ধারণে সহায়ক।</p>
            </div>

            <form class="appt-form" id="appt-form">
              <div class="form-section">
                <h3>১. রুগীর ব্যক্তিগত তথ্য</h3>
                <div class="form-grid form-grid--two">
                  <div class="form-group">
                    <label for="fullName">রুগীর পূর্ণ নাম <span class="required">*</span></label>
                    <input id="fullName" name="fullName" type="text" placeholder="পূর্ণ নাম লিখুন" required />
                  </div>
                  <div class="form-group">
                    <label for="nid">ভোটার আইডি নং</label>
                    <input id="nid" name="nid" type="text" placeholder="যদি থাকে লিখুন" />
                  </div>
                  <div class="form-group">
                    <label for="age">বয়স <span class="required">*</span></label>
                    <input id="age" name="age" type="number" min="0" max="120" placeholder="বয়স" required />
                  </div>
                  <div class="form-group">
                    <label for="weight">ওজন (কেজি)</label>
                    <input id="weight" name="weight" type="number" min="0" max="250" placeholder="ওজন" />
                  </div>
                </div>

                <div class="form-group">
                  <span class="field-title">লিঙ্গ নির্বাচন করুন <span class="required">*</span></span>
                  <div class="choice-grid">
                    {genderOptions.map((option) => (
                      <label class="choice-pill">
                        <input type="radio" name="gender" value={option} required />
                        <span>{option}</span>
                      </label>
                    ))}
                  </div>
                </div>

                <div class="form-group">
                  <span class="field-title">রিলিজিয়ন <span class="required">*</span></span>
                  <div class="choice-grid">
                    {religionOptions.map((option) => (
                      <label class="choice-pill">
                        <input type="radio" name="religion" value={option} required />
                        <span>{option}</span>
                      </label>
                    ))}
                  </div>
                </div>

                <div class="form-group">
                  <label for="duration">সমস্যার স্থায়িত্ব <span class="required">*</span></label>
                  <select id="duration" name="duration" required>
                    <option value="">একটি অপশন নির্বাচন করুন</option>
                    {durationOptions.map((option) => <option value={option}>{option}</option>)}
                  </select>
                </div>

                <div class="form-group">
                  <span class="field-title">পূর্বে কোনো ইমাম, মুয়াজ্জিন, কবিরাজ বা রুকইয়াহ করানো হয়েছে? <span class="required">*</span></span>
                  <div class="choice-grid choice-grid--compact">
                    {['হ্যাঁ', 'না'].map((option) => (
                      <label class="choice-pill">
                        <input type="radio" name="previousTreatment" value={option} required />
                        <span>{option}</span>
                      </label>
                    ))}
                  </div>
                </div>

                <div class="form-group" id="previousTreatmentDetailsWrap" hidden>
                  <label for="previousTreatmentDetails">কি ধরনের চিকিৎসা / রুকইয়াহ করা হয়েছে (সংক্ষেপে লিখুন)</label>
                  <textarea
                    id="previousTreatmentDetails"
                    name="previousTreatmentDetails"
                    rows="3"
                    placeholder="সংক্ষেপে পূর্বের চিকিৎসার বিবরণ লিখুন"
                  ></textarea>
                </div>
              </div>

              <div class="form-section">
                <h3>২. শিডিউল ও সেবার ধরণ</h3>

                <div class="form-group">
                  <span class="field-title">আপনি কোন সেবা নিতে চান? <span class="required">*</span></span>
                  <div class="choice-grid">
                    {serviceModes.map((mode) => (
                      <label class="choice-pill">
                        <input type="radio" name="serviceMode" value={mode} required />
                        <span>{mode}</span>
                      </label>
                    ))}
                  </div>
                </div>

                <div class="form-group">
                  <span class="field-title">সেশনের ধরন <span class="required">*</span></span>
                  <div class="choice-grid choice-grid--compact">
                    {sessionFormats.map((format) => (
                      <label class="choice-pill">
                        <input type="radio" name="sessionFormat" value={format} required />
                        <span>{format}</span>
                      </label>
                    ))}
                  </div>
                </div>

                <div class="form-group">
                  <label for="treatmentType">চিকিৎসার ধরন <span class="required">*</span></label>
                  <select id="treatmentType" name="treatmentType" required>
                    <option value="">চিকিৎসা নির্বাচন করুন</option>
                    {treatmentCatalog.map((service) => (
                      <option value={service.value}>{service.label}</option>
                    ))}
                  </select>
                </div>

                <div class="form-group" id="subServicesWrap" hidden>
                  <span class="field-title">প্রয়োজন অনুযায়ী sub-option নির্বাচন করুন</span>
                  <div class="subservice-grid" id="subServicesList"></div>
                </div>

                <div class="form-grid form-grid--two">
                  <div class="form-group">
                    <label for="preferredDate">পছন্দের তারিখ <span class="required">*</span></label>
                    <input id="preferredDate" name="preferredDate" type="date" required />
                  </div>
                  <div class="form-group">
                    <label for="preferredTime">পছন্দের সময় <span class="required">*</span></label>
                    <select id="preferredTime" name="preferredTime" required>
                      <option value="">সময় নির্বাচন করুন</option>
                      {preferredTimeSlots.map((slot) => <option value={slot}>{slot}</option>)}
                    </select>
                  </div>
                </div>
              </div>

              <div class="form-section">
                <h3>৩. যোগাযোগের তথ্য</h3>
                <div class="form-grid form-grid--two">
                  <div class="form-group form-group--full">
                    <label for="address">বর্তমান ঠিকানা <span class="required">*</span></label>
                    <textarea id="address" name="address" rows="3" placeholder="বর্তমান ঠিকানা লিখুন" required></textarea>
                  </div>
                  <div class="form-group">
                    <label for="phone">যোগাযোগের মোবাইল নাম্বার <span class="required">*</span></label>
                    <input id="phone" name="phone" type="tel" placeholder="01XXXXXXXXX" required />
                  </div>
                  <div class="form-group">
                    <label for="whatsapp">হোয়াটসঅ্যাপ নাম্বার (যদি ভিন্ন হয়)</label>
                    <input id="whatsapp" name="whatsapp" type="tel" placeholder="01XXXXXXXXX" />
                  </div>
                </div>
              </div>

              <div class="form-section">
                <h3>৪. বর্তমান শারীরিক ও মানসিক অবস্থা</h3>
                <div class="form-group">
                  <label for="problem">প্রধান সমস্যা / উপসর্গসমূহ বিস্তারিত লিখুন <span class="required">*</span></label>
                  <textarea
                    id="problem"
                    name="problem"
                    rows="5"
                    placeholder="যে সমস্যা, উপসর্গ বা কষ্ট নিয়ে সেবা নিতে চান তা বিস্তারিত লিখুন"
                    required
                  ></textarea>
                </div>
              </div>

              <div class="form-section">
                <h3>৫. পেমেন্ট ও বুকিং কনফার্মেশন</h3>
                <div class="payment-box">
                  <p><strong>বুকিং ফি:</strong> {paymentDetails.bookingFee}</p>
                  <p><strong>ব্যাংক:</strong> {paymentDetails.bankName}, {paymentDetails.branch}</p>
                  <p><strong>একাউন্ট নাম:</strong> {paymentDetails.accountName}</p>
                  <p><strong>একাউন্ট নাম্বার:</strong> {paymentDetails.accountNumber}</p>
                  <p><strong>বিকাশ / নগদ:</strong> {paymentDetails.accountPhone}</p>
                </div>

                <div class="form-grid form-grid--two">
                  <div class="form-group">
                    <label for="paymentMethod">পেমেন্ট মাধ্যম <span class="required">*</span></label>
                    <select id="paymentMethod" name="paymentMethod" required>
                      <option value="">পেমেন্ট মাধ্যম নির্বাচন করুন</option>
                      {paymentMethods.map((method) => <option value={method}>{method}</option>)}
                    </select>
                  </div>
                  <div class="form-group">
                    <label for="transactionId">Bank / বিকাশ / নগদ Trx ID <span class="required">*</span></label>
                    <input id="transactionId" name="transactionId" type="text" placeholder="Trx ID লিখুন" required />
                  </div>
                  <div class="form-group form-group--full">
                    <label for="paymentTimestamp">টাকা পাঠানোর তারিখ ও সময় <span class="required">*</span></label>
                    <input id="paymentTimestamp" name="paymentTimestamp" type="datetime-local" required />
                  </div>
                </div>
              </div>

              <div class="form-section">
                <div class="agreement-box">
                  <label class="agreement-check">
                    <input type="checkbox" name="agreement" required />
                    <span>
                      অ্যাপয়েন্টমেন্ট নেওয়ার মাধ্যমে আমি উপরোক্ত শর্ত, মাহরাম নীতিমালা, বুকিং ফি এবং রুকইয়াহ সেশনের নির্দেশনাবলীতে সম্মতি দিচ্ছি।
                    </span>
                  </label>
                </div>

                <button type="submit" class="btn btn-primary submit-btn">অ্যাপয়েন্টমেন্ট সাবমিট করুন</button>
                <p class="submit-help">সাবমিট করলে WhatsApp-এ আপনার তথ্য পাঠানোর অপশন খুলবে এবং নিচে বিশেষ নির্দেশনাবলী দেখানো হবে।</p>
                <p class="submit-status" id="submitStatus" aria-live="polite"></p>
              </div>
            </form>
          </section>

          <section class="content-card confirmation-card" id="confirmationGuidelines" hidden>
            <div class="section-head">
              <div>
                <span class="section-kicker">সাবমিটের পর যা দেখবেন</span>
                <h2>রুকইয়াহ সেশনের বিশেষ নির্দেশনাবলী</h2>
              </div>
              <p>আমাদের টিম আপনার সাথে যোগাযোগ করে সিরিয়াল নম্বর ও নির্ধারিত সময় জানিয়ে দেবে ইনশাআল্লাহ।</p>
            </div>

            <ul class="bullet-list">
              {postSubmitGuidelines.map((item) => <li>{item}</li>)}
            </ul>

            <div class="blessing-box">
              <strong>জাযাকুমুল্লাহু খাইরান।</strong>
              <p>আমরা আল্লাহ তাআলার নিকট আপনার পূর্ণ সুস্থতা ও শিফা কামনা করি।</p>
            </div>
          </section>
        </div>

        <aside class="appt-sidebar">
          <section class="sidebar-card sidebar-card--accent">
            <h2>যোগাযোগ তথ্য</h2>
            <p>এই নাম্বারগুলোতে কল করুন অথবা WhatsApp-এ message পাঠান।</p>

            <div class="contact-list">
              {clinicNumbers.map((contact) => (
                <div class="contact-row">
                  <div>
                    <p class="contact-label">{contact.label}</p>
                    <a href={`tel:${contact.display}`} class="contact-value">{contact.display}</a>
                  </div>
                  <a
                    class="contact-wa"
                    href={getWhatsappUrl('আসসালামু আলাইকুম, অ্যাপয়েন্টমেন্ট সম্পর্কে জানতে চাই।', contact.international)}
                    target="_blank"
                    rel="noopener"
                  >
                    WhatsApp
                  </a>
                </div>
              ))}
            </div>
          </section>

          <section class="sidebar-card">
            <h2>সময়সূচী</h2>
            <p class="sidebar-strong">{clinicSchedule.days}</p>
            <p>{clinicSchedule.hours}</p>
            <a
              class="btn btn-outline sidebar-btn"
              href={getWhatsappUrl('আসসালামু আলাইকুম, আমি অ্যাপয়েন্টমেন্টের সময় সম্পর্কে জানতে চাই।')}
              target="_blank"
              rel="noopener"
            >
              সময় জেনে নিন
            </a>
          </section>

          <section class="sidebar-card">
            <h2>Before You Book</h2>
            <ul class="bullet-list">
              {beforeYouBookChecklist.map((item) => <li>{item}</li>)}
            </ul>
          </section>

          <section class="sidebar-card">
            <h2>গুরুত্বপূর্ণ নির্দেশনা</h2>
            <ul class="bullet-list">
              {bookingInstructions.map((item) => <li>{item}</li>)}
            </ul>
          </section>

          <section class="sidebar-card sidebar-card--muted">
            <h2>দ্রুত বুকিং</h2>
            <p>ফর্ম পূরণ করার আগে জরুরি কথা বলতে চাইলে সরাসরি WhatsApp করুন।</p>
            <a
              class="btn btn-primary sidebar-btn"
              href={getWhatsappUrl('আসসালামু আলাইকুম, আমি দ্রুত অ্যাপয়েন্টমেন্ট বুক করতে চাই।', primaryContact.international)}
              target="_blank"
              rel="noopener"
            >
              WhatsApp-এ বুকিং শুরু করুন
            </a>
          </section>
        </aside>
