---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Footer from '../components/Footer.astro';
import ServiceCard from '../components/ServiceCard.astro';
import BlogCard from '../components/BlogCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts');
const blogs = allPosts
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3)
  .map(post => ({
    date: new Date(post.data.date).toLocaleDateString('bn-BD', { year: 'numeric', month: 'long', day: 'numeric' }),
    category: post.data.category ?? 'রুকইয়াহ',
    title: post.data.title,
    excerpt: post.data.excerpt ?? '',
    href: `/posts/${post.id.replace(/\.md$/, '')}`,
  }));

const services = [
  {
    title: 'রুকইয়াহ',
    description: 'কুরআন ও সুন্নাহ ভিত্তিক রুকইয়াহ চিকিৎসা। জিন, জাদু ও বদনজরের চিকিৎসায় বিশেষজ্ঞ সেবা।',
    link: '/ruqyah-diagnosis',
    bgColor: 'var(--primary-light)',
    iconColor: 'var(--primary)',
    icon: `<path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>`,
  },
  {
    title: 'হিজামা',
    description: 'সুন্নাহ সম্মত হিজামা থেরাপি। শরীরের বিভিন্ন রোগ নিরাময়ে কার্যকর ইসলামিক চিকিৎসা পদ্ধতি।',
    link: '/symptom-diagnosis',
    bgColor: '#FFF3E0',
    iconColor: '#F57C00',
    icon: `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>`,
  },
  {
    title: 'আকুপাংচার',
    description: 'ইসলামী দৃষ্টিভঙ্গিতে আকুপাংচার চিকিৎসা। শারীরিক ব্যথা ও রোগ নিরাময়ে কার্যকর।',
    link: '/symptom-diagnosis',
    bgColor: '#E8F5E9',
    iconColor: '#2E7D32',
    icon: `<polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>`,
  },
  {
    title: 'সিমটম ডায়াগনোসিস',
    description: 'আপনার লক্ষণগুলি চিহ্নিত করুন এবং সঠিক চিকিৎসা পান',
    link: '/symptom-diagnosis',
    bgColor: 'var(--primary-light)',
    iconColor: 'var(--primary)',
    icon: `<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line>`,
  },
  {
    title: 'রুকইয়া ডায়াগনোসিস',
    description: 'ধাপে ধাপে রুকইয়াহ ডায়াগনোসিস প্রক্রিয়া',
    link: '/ruqyah-diagnosis',
    bgColor: '#E0F7FA',
    iconColor: '#0288D1',
    icon: `<polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>`,
  },
  {
    title: 'রুকইয়া সাপ্লিমেন্ট',
    description: 'প্রাকৃতিক ও হালাল সাপ্লিমেন্ট',
    link: '/supplements',
    bgColor: 'var(--pink-light)',
    iconColor: '#E53E3E',
    icon: `<path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>`,
  },
  {
    title: 'রুকইয়াহ ডাউনলোড',
    description: 'রুকইয়াহ কিলোওয়াট ডাউনলোড করুন',
    link: '/pdf',
    bgColor: 'var(--purple-light)',
    iconColor: '#7C3AED',
    icon: `<path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/>`,
  },
  {
    title: 'কাউন্সেলিং',
    description: 'মানসিক ও আধ্যাত্মিক কাউন্সেলিং সেবা',
    link: '/appointment',
    bgColor: '#FFF8E1',
    iconColor: '#F9A825',
    icon: `<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>`,
  },
];

const rakis = [
  { name: 'মাহমুদুল হাসান', role: 'প্রধান রাকী', href: '/team' },
  { name: 'তাজুল ইসলাম', role: 'রুকইয়াহ বিশেষজ্ঞ', href: '/team' },
  { name: 'আবদুল করিম', role: 'হিজামা বিশেষজ্ঞ', href: '/team' },
];

const packages = [
  {
    title: 'রুকইয়াহ',
    desc: 'কুরআন ও সুন্নাহ ভিত্তিক রুকইয়াহ চিকিৎসা সেবা। জিন, জাদু ও বদনজরের চিকিৎসায় বিশেষজ্ঞ।',
    link: '/appointment',
    icon: '☪️',
  },
  {
    title: 'হিজামা',
    desc: 'সুন্নাহ সম্মত হিজামা থেরাপি। শরীরের বিভিন্ন রোগ নিরাময়ে কার্যকর।',
    link: '/appointment',
    icon: '🩸',
  },
  {
    title: 'আকুপাংচার',
    desc: 'ইসলামী দৃষ্টিভঙ্গিতে আকুপাংচার চিকিৎসা। শারীরিক ব্যথা নিরসনে দক্ষ।',
    link: '/appointment',
    icon: '🌿',
  },
];

const videos = [
  { id: 'dQw4w9WgXcQ', title: 'রুকইয়াহ সেশন পরিচিতি' },
  { id: 'dQw4w9WgXcQ', title: 'হিজামা থেরাপি গাইড' },
  { id: 'dQw4w9WgXcQ', title: 'বদনজর থেকে মুক্তি' },
  { id: 'dQw4w9WgXcQ', title: 'জাদু চিকিৎসার পদ্ধতি' },
  { id: 'dQw4w9WgXcQ', title: 'রুকইয়াহ প্রশ্নোত্তর' },
  { id: 'dQw4w9WgXcQ', title: 'আমাদের সেন্টার পরিচিতি' },
];

const galleryImages = [
  { src: 'https://images.unsplash.com/photo-1585036156171-384164a8c675?w=300&h=300&fit=crop&q=40&fm=webp', alt: 'রুকইয়া সেশন' },
  { src: 'https://images.unsplash.com/photo-1564121211835-e88c852648ab?w=300&h=300&fit=crop&q=40&fm=webp', alt: 'ইসলামিক আর্কিটেকচার' },
  { src: 'https://images.unsplash.com/photo-1606819717115-9159c900370b?w=300&h=300&fit=crop&q=40&fm=webp', alt: 'হার্বাল সাপ্লিমেন্ট' },
  { src: 'https://images.unsplash.com/photo-1518495973542-4542c06a5843?w=300&h=300&fit=crop&q=40&fm=webp', alt: 'সূর্যের আলো' },
];
---

<BaseLayout>
  <Header />

  <main>
    <!-- ① Hero -->
    <Hero />

    <!-- ② রুকইয়াহ কি এবং কেনো করা হয়? -->
    <section class="section info-section reveal">
      <div class="container info-grid">
        <div class="info-text scroll-reveal">
          <h2>রুকইয়াহ কি এবং<br/>কেনো করা হয়?</h2>
          <p>
            রুকইয়াহ হলো কুরআনের আয়াত ও হাদিসে বর্ণিত দোয়ার মাধ্যমে আধ্যাত্মিক ও শারীরিক রোগের চিকিৎসা।
            ইসলামে স্বীকৃত এই পদ্ধতিতে জিনের আছর, জাদু, বদনজর ও মানসিক সমস্যার কার্যকর চিকিৎসা করা হয়।
          </p>
          <ul class="info-bullets">
            <li>শারীরিক রোগ, যেমন মাথাব্যথা, পেটের ব্যথা, অনিদ্রা নিরাময়</li>
            <li>মানসিক অস্থিরতা, ভয়, উদ্বেগ ও বিষণ্নতা থেকে মুক্তি</li>
            <li>বদনজর, হাসদ ও জাদুর প্রভাব থেকে রক্ষা</li>
            <li>জিনের আছর ও ওয়াসওয়াসা দূর করা</li>
            <li>বিয়ে, সন্তান ও রিজিকে বাধা দূর করা</li>
          </ul>
          <a class="whatsapp-cta" href="https://wa.me/8801992575874" target="_blank" rel="noopener">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            যোগাযোগ করুন: +880 1992 575874
          </a>
        </div>
        <div class="info-media scroll-reveal" style="--stagger-delay:100ms">
          <div class="info-img-wrap">
            <img
              src="/images/ruqyah-info.webp"
              alt="রুকইয়াহ — কুরআন তেলাওয়াত"
              width="600" height="600"
              loading="lazy"
              decoding="async"
              class="info-img"
            />
          </div>
          <a href="/appointment" class="btn btn-primary appt-btn" style="margin-top:16px;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            অ্যাপয়েন্টমেন্ট বুক করুন
          </a>
        </div>
      </div>
    </section>

    <!-- ③ হিজামা কি এবং কেনো করা হয়? -->
    <section class="section info-section info-section--alt reveal" style="background:var(--bg-light)">
      <div class="container info-grid info-grid--reverse">
        <div class="info-media scroll-reveal">
          <div class="hijama-images">
            <img src="/images/hijama-main.webp" alt="হিজামা কাপিং থেরাপি" class="hijama-img hijama-img--main" loading="lazy" width="400" height="500" />
             <img src="/images/hijama-secondary.webp" alt="কুরআন ও তাসবিহ" class="hijama-img hijama-img--secondary" loading="lazy" width="200" height="200" />
          </div>
        </div>
        <div class="info-text scroll-reveal" style="--stagger-delay:100ms">
          <h2>হিজামা কি এবং<br/>কেনো করা হয়?</h2>
          <p>
            হিজামা বা কাপিং থেরাপি হলো নবী মুহাম্মদ (সা.) কর্তৃক অনুমোদিত একটি চিকিৎসা পদ্ধতি। শরীরের নির্দিষ্ট
            স্থানে কাপ লাগিয়ে দূষিত রক্ত বের করে নেওয়া হয়।
          </p>
          <ul class="info-bullets">
            <li>শারীরিক ব্যথা ও প্রদাহ কমায়</li>
            <li>রক্ত সঞ্চালন উন্নত করে</li>
            <li>রোগ প্রতিরোধ ক্ষমতা বাড়ায়</li>
            <li>মাইগ্রেন, উচ্চ রক্তচাপ নিরাময়ে সহায়ক</li>
            <li>মানসিক চাপ ও ক্লান্তি দূর করে</li>
          </ul>
          <a class="whatsapp-cta" href="https://wa.me/8801992575874" target="_blank" rel="noopener">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            যোগাযোগ করুন: +880 1992 575874
          </a>
        </div>
      </div>
    </section>

    <!-- ④ আমাদের সেবাসমূহ (8-card grid) -->
    <section class="section reveal">
      <div class="container">
        <div class="section-header scroll-reveal">
          <h2>আমাদের সেবাসমূহ</h2>
          <p>ইসলামিক পদ্ধতিতে আপনার সুস্থতার জন্য আমাদের বিশেষ সেবাসমূহ</p>
        </div>
        <div class="grid-4 services-grid">
          {services.map((service, i) => (
            <div class="scroll-reveal-child svc-wrap" style={`--stagger-delay: ${i * 60}ms`}>
              <ServiceCard {...service} />
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ⑤ রুকইয়া ব্লগ -->
    <section class="section reveal" style="background:var(--bg-light)">
      <div class="container">
        <div class="section-header-row scroll-reveal">
          <div>
            <h2>রুকইয়া ব্লগ</h2>
            <p>সর্বশেষ নিবন্ধ এবং তথ্য</p>
          </div>
          <a href="/blog" class="btn btn-outline btn-sm">সব দেখুন</a>
        </div>
        <div class="blog-grid-desktop">
          {blogs.map(post => (
            <div class="scroll-reveal-child"><BlogCard {...post} /></div>
          ))}
        </div>
        <div class="blog-swipe-mobile" id="blog-swipe">
          {blogs.map(post => (
            <div class="blog-swipe-item"><BlogCard {...post} /></div>
          ))}
        </div>
        <div class="swipe-hint" aria-hidden="true"><span>← সোয়াইপ করুন →</span></div>
      </div>
    </section>

    <!-- ⑥ আমাদের ভিডিও -->
    <section class="section reveal">
      <div class="container">
        <div class="section-header scroll-reveal">
          <h2>আমাদের ভিডিও</h2>
          <p>রুকইয়াহ ও হিজামা সম্পর্কিত শিক্ষামূলক ভিডিও</p>
        </div>
        <div class="video-grid">
          {videos.map((v, i) => (
            <div class="video-card scroll-reveal-child" style={`--stagger-delay:${i*60}ms`}>
              <a href={`https://www.youtube.com/watch?v=${v.id}`} target="_blank" rel="noopener" class="video-thumb-link" aria-label={v.title}>
                <img
                  src={`https://img.youtube.com/vi/${v.id}/mqdefault.jpg`}
                  alt={v.title}
                  loading="lazy"
                  width="320"
                  height="180"
                />
                <div class="play-btn" aria-hidden="true">
                  <svg width="40" height="40" viewBox="0 0 24 24" fill="red"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.18 8.18 0 004.77 1.52V6.77a4.85 4.85 0 01-1-.08z"/></svg>
                </div>
              </a>
              <p class="video-title">{v.title}</p>
            </div>
          ))}
        </div>
