<script>
  function initHomePage() {
    // ── Scroll-reveal
    const revealEls = document.querySelectorAll('.reveal');
    if ('IntersectionObserver' in window) {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.07 }
      );
      revealEls.forEach(el => observer.observe(el));
    } else {
      revealEls.forEach(el => el.classList.add('is-visible'));
    }

    // ── Stats counter
    function animateCounter(el: Element, target: number, suffix: string, duration = 1200) {
      let start = 0;
      const step = (timestamp: number) => {
        if (!start) start = timestamp;
        const progress = Math.min((timestamp - start) / duration, 1);
        const eased = 1 - Math.pow(1 - progress, 3);
        el.textContent = Math.floor(eased * target) + suffix;
        if (progress < 1) requestAnimationFrame(step);
      };
      requestAnimationFrame(step);
    }
    const statsObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (!entry.isIntersecting) return;
        const el = entry.target as HTMLElement;
        const raw = el.dataset.count ?? '';
        const target = parseInt(raw, 10);
        const suffix = el.dataset.suffix ?? '';
        if (!isNaN(target)) animateCounter(el, target, suffix);
        statsObserver.unobserve(el);
      });
    }, { threshold: 0.5 });
    document.querySelectorAll('[data-count]').forEach(el => statsObserver.observe(el));

    // ── Swipe hint
    const swipeHint = document.querySelector('.swipe-hint') as HTMLElement | null;
    if (swipeHint) {
      swipeHint.classList.remove('faded');
      setTimeout(() => swipeHint.classList.add('faded'), 2500);
    }

    // ── Raki mobile carousel dots
    const rakiSwipe = document.getElementById('raki-swipe') as HTMLElement | null;
    const rakiDots  = document.querySelectorAll('#raki-dots .raki-dot');

    function setRakiDot(i: number) {
      rakiDots.forEach((d, idx) => d.classList.toggle('active', idx === i));
    }

    // Dots → scroll
    rakiDots.forEach((dot, i) => {
      dot.addEventListener('click', () => {
        if (!rakiSwipe) return;
        const items = rakiSwipe.querySelectorAll('.raki-swipe-item');
        if (items[i]) (items[i] as HTMLElement).scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'start' });
        setRakiDot(i);
      });
    });

    // Scroll → dots
    if (rakiSwipe) {
      let rakiScrollTimer: ReturnType<typeof setTimeout>;
      rakiSwipe.addEventListener('scroll', () => {
        clearTimeout(rakiScrollTimer);
        rakiScrollTimer = setTimeout(() => {
          const itemW = (rakiSwipe.querySelector('.raki-swipe-item') as HTMLElement)?.offsetWidth ?? 1;
          const idx = Math.round(rakiSwipe.scrollLeft / itemW);
          setRakiDot(idx);
        }, 80);
      }, { passive: true });
    }
  }

  // ── Prayer Times (Aladhan API) ──────────────────────────
  async function loadPrayerTimes() {
    const set = (id: string, val: string) => {
      const el = document.getElementById(id);
      if (el) el.textContent = val;
    };

    const fmt = (t: string) => {
      // "16:30" → "4:30pm"
      const [h, m] = t.split(':').map(Number);
      const ampm = h >= 12 ? 'pm' : 'am';
      const h12 = h % 12 || 12;
      return `${h12}:${String(m).padStart(2,'0')}${ampm}`;
    };

    const highlightNext = (timings: Record<string,string>) => {
      const keys: [string, string][] = [
        ['Fajr','pt-fajr'],['Dhuhr','pt-dhuhr'],['Asr','pt-asr'],
        ['Maghrib','pt-maghrib'],['Isha','pt-isha']
      ];
      const now = new Date();
      const nowMin = now.getHours() * 60 + now.getMinutes();
      let nextKey = keys[0][0];
      for (const [k] of keys) {
        const [h, m] = (timings[k] || '0:0').split(':').map(Number);
        if (h * 60 + m > nowMin) { nextKey = k; break; }
      }
      document.querySelectorAll('.pw-prayer-item').forEach(el => el.classList.remove('next-prayer'));
      const nextEl = document.querySelector(`.pw-prayer-item[data-prayer="${nextKey}"]`);
      if (nextEl) nextEl.classList.add('next-prayer');
    };

    const apiFetch = async (lat: number, lng: number) => {
      const url = `https://api.aladhan.com/v1/timings?latitude=${lat}&longitude=${lng}&method=1`;
      const r = await fetch(url);
      if (!r.ok) throw new Error('api fail');
      return (await r.json()).data;
    };

    const geocode = async (lat: number, lng: number) => {
      try {
        const r = await fetch(`https://nominatim.openstreetmap.org/reverse?lat=${lat}&lon=${lng}&format=json`);
        const d = await r.json();
        const city = d.address?.city || d.address?.town || d.address?.village || 'N/A';
        const country = d.address?.country || '';
        (document.getElementById('pt-city') as HTMLElement).textContent = city;
        (document.getElementById('pt-country') as HTMLElement).textContent = country;
      } catch {}
    };

    const render = (data: any) => {
      const t = data.timings;
      set('pt-sunrise', fmt(t.Sunrise));
      set('pt-fajr',    fmt(t.Fajr));
      set('pt-dhuhr',   fmt(t.Dhuhr));
      set('pt-asr',     fmt(t.Asr));
      set('pt-maghrib', fmt(t.Maghrib));
      set('pt-isha',    fmt(t.Isha));
      highlightNext(t);
    };

    try {
      if ('geolocation' in navigator) {
        navigator.geolocation.getCurrentPosition(
          async ({ coords: { latitude: lat, longitude: lng } }) => {
            try {
              const data = await apiFetch(lat, lng);
              render(data);
              geocode(lat, lng);
            } catch {}
          },
          async () => {
            // fallback → Dhaka
            const data = await apiFetch(23.8103, 90.4125);
            render(data);
          },
          { timeout: 6000 }
        );
      } else {
        const data = await apiFetch(23.8103, 90.4125);
        render(data);
      }
    } catch {}
  }

  loadPrayerTimes();

  initHomePage();
  document.addEventListener('astro:page-load', initHomePage);

</script>

