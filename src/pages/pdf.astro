---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const pdfs = [
  { title: 'রুকইয়া সম্পূর্ণ গাইড', desc: 'রুকইয়া করার বিস্তারিত পদ্ধতি এবং দোয়া সংকলন', pages: 45, size: '2.5 MB', category: 'গাইড', lang: 'বাংলা' },
  { title: 'সকাল-সন্ধ্যার দোয়া', desc: 'প্রতিদিন পাঠ করার জন্য গুরুত্বপূর্ণ দোয়া', pages: 12, size: '800 KB', category: 'দোয়া', lang: 'বাংলা-আরবি' },
  { title: 'জিন এবং শয়তান থেকে সুরক্ষা', desc: 'ইসলামিক শিক্ষা অনুযায়ী সুরক্ষার উপায়', pages: 32, size: '1.8 MB', category: 'সুরক্ষা', lang: 'বাংলা' },
  { title: 'কুরআনের শিফা আয়াত', desc: 'কুরআনে বর্ণিত সকল সুস্থতার আয়াত', pages: 28, size: '1.2 MB', category: 'কুরআন', lang: 'বাংলা-আরবি' },
  { title: 'পরিবারের জন্য রুকইয়াহ', desc: 'পরিবারের সকল সদস্যের সুরক্ষার দোয়া', pages: 20, size: '950 KB', category: 'পরিবার', lang: 'বাংলা' },
  { title: 'ডায়াগনোসিস গাইডলাইন', desc: 'লক্ষণ বিশ্লেষণ ও চিকিৎসা পদ্ধতির বিস্তারিত', pages: 38, size: '2.0 MB', category: 'ডায়াগনোসিস', lang: 'বাংলা' },
];

const categories = ['সব', 'গাইড', 'দোয়া', 'সুরক্ষা', 'কুরআন', 'পরিবার', 'ডায়াগনোসিস'];
---

<BaseLayout title="পিডিএফ ডাউনলোড | Ruqyah Healing Center" description="রুকইয়াহ এবং ইসলামিক হিলিং সম্পর্কিত বই, গাইড এবং দোয়া সংকলন ডাউনলোড করুন।">
  <Header />

  <main>
    <div class="page-header">
      <div class="container">
        <nav class="breadcrumb">
          <a href="/">হোম</a><span>/</span><span>পিডিএফ</span>
        </nav>
      </div>
    </div>

    <section class="pdf-hero">
      <div class="container">
        <h1>পিডিএফ ডাউনলোড</h1>
        <p>রুকইয়াহ এবং ইসলামিক হিলিং সম্পর্কিত বই, গাইড এবং দোয়া সংকলন</p>

        <div class="search-box">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
          </svg>
          <input type="text" placeholder="পিডিএফ খুঁজুন..." />
        </div>

        <div class="cat-tabs">
          {categories.map((cat, i) => (
            <button class:list={['cat-btn', i === 0 && 'active']}>{cat}</button>
          ))}
        </div>
      </div>
    </section>

    <section class="pdf-section">
      <div class="container">
        <div class="pdf-grid">
          {pdfs.map(pdf => (
            <div class="pdf-card">
              <div class="pdf-icon-wrap">
                <div class="pdf-icon">
                  <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                    <polyline points="14 2 14 8 20 8"/>
                    <line x1="16" y1="13" x2="8" y2="13"/>
                    <line x1="16" y1="17" x2="8" y2="17"/>
                    <polyline points="10 9 9 9 8 9"/>
                  </svg>
                </div>
              </div>
              <div class="pdf-body">
                <h3>{pdf.title}</h3>
                <p>{pdf.desc}</p>
                <div class="pdf-meta">
                  <div class="meta-item">
                    <span class="meta-label">পৃষ্ঠা</span>
                    <span class="meta-value">{pdf.pages}</span>
                  </div>
                  <div class="meta-item">
                    <span class="meta-label">আকার</span>
                    <span class="meta-value">{pdf.size}</span>
                  </div>
                  <div class="meta-item">
                    <span class="meta-label">ক্যাটাগরি</span>
                    <span class="meta-value">{pdf.category}</span>
                  </div>
                  <div class="meta-item">
                    <span class="meta-label">ভাষা</span>
                    <span class="meta-value">{pdf.lang}</span>
                  </div>
                </div>
                <div class="pdf-actions">
                  <button class="view-btn">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
                    </svg>
                    দেখুন
                  </button>
                  <button class="download-btn">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                      <polyline points="7 10 12 15 17 10"/>
                      <line x1="12" y1="15" x2="12" y2="3"/>
                    </svg>
                    ডাউনলোড
                  </button>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
.page-header { padding: 16px 0; border-bottom: 1px solid var(--border); }
.breadcrumb { display: flex; gap: 8px; align-items: center; font-size: 14px; color: var(--text-muted); }
.breadcrumb a { color: var(--primary); text-decoration: none; }

.pdf-hero { padding: 48px 0 32px; text-align: center; }
.pdf-hero h1 { font-size: 2rem; font-weight: 700; margin-bottom: 10px; }
.pdf-hero p { color: var(--text-muted); margin-bottom: 24px; }

.search-box { display: flex; align-items: center; gap: 12px; background: #fff; border: 1px solid var(--border); border-radius: 12px; padding: 12px 20px; max-width: 600px; margin: 0 auto 20px; }
.search-box svg { color: var(--text-muted); flex-shrink: 0; }
.search-box input { flex: 1; border: none; outline: none; font-size: 15px; font-family: inherit; }

.cat-tabs { display: flex; gap: 8px; justify-content: center; flex-wrap: wrap; }
.cat-btn { padding: 7px 18px; border: 1px solid var(--border); border-radius: 20px; background: #fff; font-size: 13px; cursor: pointer; font-family: inherit; transition: all 0.2s; }
.cat-btn:hover, .cat-btn.active { background: var(--primary); color: #fff; border-color: var(--primary); }

.pdf-section { padding: 32px 0 64px; }
.pdf-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }

.pdf-card { background: #fff; border: 1px solid var(--border); border-radius: 16px; padding: 24px; transition: all 0.2s; }
.pdf-card:hover { box-shadow: var(--shadow-md); transform: translateY(-2px); }
.pdf-icon-wrap { margin-bottom: 16px; }
.pdf-icon { width: 56px; height: 56px; background: #fee2e2; border-radius: 12px; display: flex; align-items: center; justify-content: center; }
.pdf-icon svg { color: #dc2626; stroke: #dc2626; }
.pdf-body h3 { font-size: 16px; font-weight: 700; margin-bottom: 6px; }
.pdf-body > p { font-size: 13px; color: var(--text-muted); margin-bottom: 16px; line-height: 1.5; }

.pdf-meta { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 16px; }
.meta-item { }
.meta-label { display: block; font-size: 11px; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px; }
.meta-value { font-size: 14px; font-weight: 600; color: var(--text-dark); }

.pdf-actions { display: flex; gap: 10px; }
.view-btn, .download-btn { display: flex; align-items: center; gap: 6px; padding: 9px 14px; border-radius: 10px; font-size: 13px; font-weight: 600; cursor: pointer; font-family: inherit; transition: all 0.2s; flex: 1; justify-content: center; }
.view-btn { border: 1px solid var(--border); background: #fff; color: var(--text-dark); }
.view-btn:hover { border-color: var(--primary); color: var(--primary); }
.download-btn { background: var(--primary); color: #fff; border: none; }
.download-btn:hover { background: var(--primary-dark); }

@media (max-width: 900px) { .pdf-grid { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 560px) { .pdf-grid { grid-template-columns: 1fr; } }
</style>
