---
import '../styles/global.css';
import BottomNav from '../components/BottomNav.astro';
import AIAgent from '../components/AIAgent.astro';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  articleDate?: string;
  articleAuthor?: string;
  articleSection?: string;
  keywords?: string[];
  noindex?: boolean;
}

const {
  title = 'রুকইয়াহ হিলিং সেন্টার | Ruqyah Healing Center',
  description = 'ইসলামী রুকইয়ার মাধ্যমে হালাল হিলিং সার্ভিস। কুরআন এবং সুন্নাহ ভিত্তিক চিকিৎসা পদ্ধতিতে আপনার আধ্যাত্মিক ও শারীরিক সুস্থতা নিশ্চিত করুন।',
  ogImage = '/og-default.jpg',
  ogType = 'website',
  articleDate,
  articleAuthor = 'মুফতী মুহাম্মাদ আল-আমীন',
  articleSection,
  keywords = ['রুকইয়াহ', 'ইসলামিক হিলিং', 'জ্বীন', 'বদনজর', 'কালো জাদু', 'ruqyah', 'islamic healing'],
  noindex = false,
} = Astro.props;

const siteUrl   = 'https://ruqyah-healing.pages.dev';
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).href;
const ogImageFull  = new URL(ogImage, siteUrl).href;
const siteName = 'রুকইয়াহ হিলিং সেন্টার';
---
<!doctype html>
<html lang="bn">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Primary SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords.join(', ')} />
    <meta name="author" content={articleAuthor} />
    <meta name="theme-color" content="#10B981" />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    {!noindex && <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1" />}

    <!-- Canonical -->
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Open Graph / Facebook -->
    <meta property="og:site_name" content={siteName} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageFull} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="bn_BD" />
    {ogType === 'article' && articleDate && (
      <meta property="article:published_time" content={articleDate} />
    )}
    {ogType === 'article' && articleAuthor && (
      <meta property="article:author" content={articleAuthor} />
    )}
    {ogType === 'article' && articleSection && (
      <meta property="article:section" content={articleSection} />
    )}

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageFull} />

    <!-- Preconnect to Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- Async Google Fonts (non-render-blocking) -->
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Hind+Siliguri:wght@400;600;700&family=Lora:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Raleway:wght@300;400;500;600;700&display=swap"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Hind+Siliguri:wght@400;600;700&family=Lora:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Raleway:wght@300;400;500;600;700&display=swap"
      />
    </noscript>

    <!-- Preload hero background image for fast LCP -->
    <link rel="preload" as="image" href="/images/hero-bg.webp" type="image/webp" fetchpriority="high" />

    <!-- Slot for page-specific head content (e.g. JSON-LD) -->
    <slot name="head" />

    <!-- Astro View Transitions (official API from astro:transitions) -->
    <ClientRouter fallback="swap" />
  </head>
  <body>
    <slot />
    <BottomNav />

    <!-- WhatsApp Floating Button -->
    <a
      href="https://wa.me/8801992575874"
      target="_blank"
      rel="noopener noreferrer"
      class="wa-float"
      aria-label="WhatsApp এ যোগাযোগ করুন"
      title="WhatsApp এ যোগাযোগ করুন"
    >
      <svg width="28" height="28" viewBox="0 0 24 24" fill="white">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
      <span class="wa-tooltip">WhatsApp করুন</span>
    </a>
    <AIAgent />
  </body>
</html>
