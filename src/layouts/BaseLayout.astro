---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  articleDate?: string;
  articleAuthor?: string;
  articleSection?: string;
  keywords?: string[];
  noindex?: boolean;
}

const {
  title = 'রুকইয়াহ হিলিং সেন্টার | Ruqyah Healing Center',
  description = 'ইসলামী রুকইয়ার মাধ্যমে হালাল হিলিং সার্ভিস। কুরআন এবং সুন্নাহ ভিত্তিক চিকিৎসা পদ্ধতিতে আপনার আধ্যাত্মিক ও শারীরিক সুস্থতা নিশ্চিত করুন।',
  ogImage = '/og-default.jpg',
  ogType = 'website',
  articleDate,
  articleAuthor = 'মুফতী মুহাম্মাদ আল-আমীন',
  articleSection,
  keywords = ['রুকইয়াহ', 'ইসলামিক হিলিং', 'জ্বীন', 'বদনজর', 'কালো জাদু', 'ruqyah', 'islamic healing'],
  noindex = false,
} = Astro.props;

const siteUrl   = 'https://ruqyah-healing.pages.dev';
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).href;
const ogImageFull  = new URL(ogImage, siteUrl).href;
const siteName = 'রুকইয়াহ হিলিং সেন্টার';
---
<!doctype html>
<html lang="bn">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Primary SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords.join(', ')} />
    <meta name="author" content={articleAuthor} />
    <meta name="theme-color" content="#10B981" />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    {!noindex && <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1" />}

    <!-- Canonical -->
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Open Graph / Facebook -->
    <meta property="og:site_name" content={siteName} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageFull} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="bn_BD" />
    {ogType === 'article' && articleDate && (
      <meta property="article:published_time" content={articleDate} />
    )}
    {ogType === 'article' && articleAuthor && (
      <meta property="article:author" content={articleAuthor} />
    )}
    {ogType === 'article' && articleSection && (
      <meta property="article:section" content={articleSection} />
    )}

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageFull} />

    <!-- Preconnect to Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- Async Google Fonts (non-render-blocking) -->
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Hind+Siliguri:wght@400;600;700&family=Lora:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Raleway:wght@300;400;500;600;700&display=swap"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Hind+Siliguri:wght@400;600;700&family=Lora:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Raleway:wght@300;400;500;600;700&display=swap"
      />
    </noscript>

    <!-- Slot for page-specific head content (e.g. JSON-LD) -->
    <slot name="head" />
  </head>
  <body>
    <slot />
  </body>
</html>
